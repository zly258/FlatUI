<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#3794FF</Color>
    <Color x:Key="PrimaryHoverColor">#58A6FF</Color>
    <Color x:Key="PrimaryPressedColor">#1F6FEB</Color>
    
    <!-- Neutral Colors -->
    <Color x:Key="BackgroundColor">#0D1117</Color>
    <Color x:Key="RegionColor">#161B22</Color>
    <Color x:Key="BorderColor">#30363D</Color>
    <Color x:Key="BorderHoverColor">#8B949E</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextColor">#C9D1D9</Color>
    <Color x:Key="TextSecondaryColor">#8B949E</Color>
    <Color x:Key="TextDisabledColor">#484F58</Color>
    <Color x:Key="WhiteTextColor">#FFFFFF</Color>
</ResourceDictionary>