<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Bubble 气泡卡片控件样式 -->
    
    <Style x:Key="DefaultBubbleStyle" TargetType="{x:Type controls:Bubble}">
        <Setter Property="MaxWidth" Value="400"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="BubbleBackground" Value="{DynamicResource RegionBrush}"/>
        <Setter Property="BubbleForeground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="AvatarSize" Value="40"/>
        <Setter Property="Position" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Bubble}">
                    <Grid Margin="{TemplateBinding Margin}" 
                          MaxWidth="{TemplateBinding MaxWidth}">
                        
                        <Grid.ColumnDefinitions>
                            <!-- 头像列 -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- 内容列 -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 头像区域（左侧位置） -->
                        <Border x:Name="avatarBorder"
                                Width="{TemplateBinding AvatarSize}"
                                Height="{TemplateBinding AvatarSize}"
                                CornerRadius="{TemplateBinding AvatarSize, Converter={StaticResource DoubleToHalfConverter}}"
                                Background="{DynamicResource PrimaryBrush}"
                                Visibility="Visible"
                                Margin="0,0,10,0">
                            
                            <Grid>
                                <!-- 头像图片 -->
                                <Image x:Name="avatarImage"
                                       Source="{TemplateBinding AvatarSource}"
                                       Stretch="UniformToFill"
                                       Clip="{Binding ElementName=avatarBorder, Path=ActualWidth, Converter={StaticResource WidthToClipConverter}}"
                                       Visibility="Collapsed"/>
                                
                                <!-- 头像文字 -->
                                <TextBlock x:Name="avatarText"
                                           Text="{TemplateBinding AvatarText}"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Visible"/>
                            </Grid>
                        </Border>
                        
                        <!-- 气泡内容区域 -->
                        <StackPanel Grid.Column="1">
                            <!-- 发送者信息 -->
                            <Grid x:Name="senderInfo" Visibility="Visible" Margin="0,0,0,4">
                                <TextBlock x:Name="senderNameText"
                                           Text="{TemplateBinding SenderName}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Visibility="Visible"/>
                                
                                <TextBlock x:Name="timestampText"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Timestamp, StringFormat='{}{0:HH:mm}'}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"
                                           Visibility="Visible"/>
                            </Grid>
                            
                            <!-- 气泡主体 -->
                            <Border x:Name="bubbleBorder"
                                    Background="{TemplateBinding BubbleBackground}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="12"
                                    HorizontalAlignment="Left">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.1"/>
                                </Border.Effect>
                                
                                <ContentPresenter ContentSource="Content"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- 位置切换 - 右侧 -->
                        <Trigger Property="Position" Value="Right">
                            <Setter TargetName="avatarBorder" Property="Grid.Column" Value="2"/>
                            <Setter TargetName="avatarBorder" Property="Margin" Value="10,0,0,0"/>
                            <Setter TargetName="senderInfo" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="bubbleBorder" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="bubbleBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                        </Trigger>
                        
                        <!-- 隐藏头像 -->
                        <Trigger Property="ShowAvatar" Value="False">
                            <Setter TargetName="avatarBorder" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- 隐藏发送者名称 -->
                        <Trigger Property="ShowSenderName" Value="False">
                            <Setter TargetName="senderNameText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- 隐藏时间戳 -->
                        <Trigger Property="ShowTimestamp" Value="False">
                            <Setter TargetName="timestampText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- 头像图片显示 -->
                        <Trigger Property="AvatarSource" Value="{x:Null}">
                            <Setter TargetName="avatarImage" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="avatarText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 对话气泡样式 -->
    <Style x:Key="ChatBubbleStyle" TargetType="{x:Type controls:Bubble}" BasedOn="{StaticResource DefaultBubbleStyle}">
        <Setter Property="ShowAvatar" Value="True"/>
        <Setter Property="ShowSenderName" Value="True"/>
        <Setter Property="ShowTimestamp" Value="True"/>
    </Style>
    
    <!-- 简单气泡样式（无头像和信息） -->
    <Style x:Key="SimpleBubbleStyle" TargetType="{x:Type controls:Bubble}" BasedOn="{StaticResource DefaultBubbleStyle}">
        <Setter Property="ShowAvatar" Value="False"/>
        <Setter Property="ShowSenderName" Value="False"/>
        <Setter Property="ShowTimestamp" Value="False"/>
    </Style>
    
    <!-- 默认样式 -->
    <Style TargetType="{x:Type controls:Bubble}" BasedOn="{StaticResource DefaultBubbleStyle}"/>

</ResourceDictionary>
