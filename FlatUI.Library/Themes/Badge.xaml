<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">

    <!-- Badge 徽标控件样式 -->
    
    <Style x:Key="DefaultBadgeStyle" TargetType="{x:Type controls:Badge}">
        <Setter Property="MinWidth" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BadgeBackground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BadgeForeground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BadgeSize" Value="Medium"/>
        <Setter Property="IsDot" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Badge}">
                    <Grid>
                        <!-- 内容区域 -->
                        <ContentPresenter x:Name="contentPresenter" 
                                          ContentSource="Content"
                                          Visibility="{TemplateBinding Content, Converter={StaticResource NullToVisibilityConverter}}"/>
                        
                        <!-- 徽标容器 -->
                        <Border x:Name="badgeBorder"
                                Background="{TemplateBinding BadgeBackground}"
                                CornerRadius="10"
                                MinWidth="{TemplateBinding MinWidth}"
                                Height="{TemplateBinding Height}"
                                Padding="{TemplateBinding Padding}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.2"/>
                            </Border.Effect>
                            
                            <!-- 状态点模式 -->
                            <TextBlock x:Name="badgeText"
                                       Text="{TemplateBinding DisplayText}"
                                       Foreground="{TemplateBinding BadgeForeground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Visible"/>
                        </Border>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- 点状模式 -->
                        <Trigger Property="IsDot" Value="True">
                            <Setter TargetName="badgeBorder" Property="MinWidth" Value="8"/>
                            <Setter TargetName="badgeBorder" Property="Height" Value="8"/>
                            <Setter TargetName="badgeBorder" Property="Padding" Value="0"/>
                            <Setter TargetName="badgeText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- 尺寸切换 -->
                        <Trigger Property="BadgeSize" Value="Small">
                            <Setter Property="MinWidth" Value="16"/>
                            <Setter Property="Height" Value="16"/>
                            <Setter Property="Padding" Value="4,0"/>
                            <Setter Property="FontSize" Value="10"/>
                        </Trigger>
                        
                        <Trigger Property="BadgeSize" Value="Large">
                            <Setter Property="MinWidth" Value="24"/>
                            <Setter Property="Height" Value="24"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="FontSize" Value="14"/>
                        </Trigger>
                        
                        <!-- 状态类型切换 -->
                        <Trigger Property="Status" Value="Success">
                            <Setter Property="BadgeBackground" Value="{DynamicResource SuccessBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="Warning">
                            <Setter Property="BadgeBackground" Value="{DynamicResource WarningBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="Error">
                            <Setter Property="BadgeBackground" Value="{DynamicResource ErrorBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="Info">
                            <Setter Property="BadgeBackground" Value="{DynamicResource InfoBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="Processing">
                            <Setter Property="BadgeBackground" Value="{DynamicResource ProcessingBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 计数徽标样式 -->
    <Style x:Key="CountBadgeStyle" TargetType="{x:Type controls:Badge}" BasedOn="{StaticResource DefaultBadgeStyle}">
        <Setter Property="BadgeType" Value="Count"/>
    </Style>
    
    <!-- 状态徽标样式 -->
    <Style x:Key="StatusBadgeStyle" TargetType="{x:Type controls:Badge}" BasedOn="{StaticResource DefaultBadgeStyle}">
        <Setter Property="BadgeType" Value="Status"/>
        <Setter Property="IsDot" Value="True"/>
    </Style>
    
    <!-- 默认样式 -->
    <Style TargetType="{x:Type controls:Badge}" BasedOn="{StaticResource DefaultBadgeStyle}"/>

</ResourceDictionary>
