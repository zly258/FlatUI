<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">
    
    <Style TargetType="{x:Type controls:FlatCard}">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <!-- CornerRadius 属性将在模板中设置 -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlatCard}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        
                        <!-- 阴影效果 -->
                        <Border.Effect>
                            <DropShadowEffect x:Name="ShadowEffect"
                                              BlurRadius="{Binding ShadowDepth, Converter={StaticResource ShadowDepthToBlurConverter}}"
                                              ShadowDepth="{Binding ShadowDepth, Converter={StaticResource ShadowDepthToShadowConverter}}"
                                              Color="#20000000"/>
                        </Border.Effect>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 头部 -->
                            <Border x:Name="HeaderBorder"
                                    Grid.Row="0"
                                    Background="{DynamicResource RegionBrush}"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Visibility="{TemplateBinding ShowHeader, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ContentPresenter x:Name="HeaderPresenter"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  Margin="15,10"/>
                            </Border>
                            
                            <!-- 内容 -->
                            <ContentPresenter Grid.Row="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Margin="15,10"/>
                            
                            <!-- 底部 -->
                            <Border x:Name="FooterBorder"
                                    Grid.Row="2"
                                    Background="{DynamicResource RegionBrush}"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    CornerRadius="0,0,{Binding CornerRadius.BottomRight, ElementName=RootBorder},0,0,{Binding CornerRadius.BottomLeft, ElementName=RootBorder}"
                                    Visibility="{TemplateBinding ShowFooter, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ContentPresenter x:Name="FooterPresenter"
                                                  Content="{TemplateBinding Footer}"
                                                  ContentTemplate="{TemplateBinding FooterTemplate}"
                                                  Margin="15,10"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <!-- 悬停效果 -->
                        <Trigger Property="IsHoverable" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="20" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                         Storyboard.TargetProperty="ShadowDepth"
                                                         To="4" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ShadowEffect"
                                                         Storyboard.TargetProperty="ShadowDepth"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>