<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">
    
    <Style TargetType="{x:Type controls:FlatExampleContainer}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlatExampleContainer}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 标题栏 -->
                            <Border Grid.Row="0" 
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="4,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding Title}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="15,10"/>
                                    
                                    <Button x:Name="PART_ViewSourceButton"
                                            Grid.Column="1"
                                            Content="查看源码"
                                            Style="{DynamicResource FlatButton}"
                                            Margin="0,0,15,0"
                                            Padding="8,4"/>
                                </Grid>
                            </Border>
                            
                            <!-- 示例内容 -->
                            <Border Grid.Row="1" 
                                    Background="{DynamicResource BackgroundBrush}"
                                    Margin="15">
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </Border>
                            
                            <!-- 描述区域 -->
                            <Border Grid.Row="2" 
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    CornerRadius="0,0,4,4"
                                    Visibility="{TemplateBinding Description, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{TemplateBinding Description}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="15,8"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_ViewSourceButton" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_ViewSourceButton" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="PART_ViewSourceButton" Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
                        </Trigger>
                        
                        <Trigger SourceName="PART_ViewSourceButton" Property="IsPressed" Value="True">
                            <Setter TargetName="PART_ViewSourceButton" Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>