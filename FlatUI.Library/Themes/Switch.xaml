<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">
    
    <Style TargetType="{x:Type controls:FlatSwitch}">
        <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlatSwitch}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 开关滑块 -->
                            <Border x:Name="Thumb"
                                    Grid.Column="0"
                                    Background="{DynamicResource WhiteTextBrush}"
                                    Width="20" Height="20"
                                    CornerRadius="10"
                                    Margin="2">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Color="#40000000"/>
                                </Border.Effect>
                            </Border>
                            
                            <!-- 开关文本 -->
                            <ContentPresenter x:Name="TextPresenter"
                                              Grid.Column="1"
                                              Content="{TemplateBinding OffContent}"
                                              Margin="5,0,10,0"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Visibility="{TemplateBinding ShowText, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <!-- 选中状态 -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0,2,2,2"/>
                            <Setter TargetName="Thumb" Property="Grid.Column" Value="1"/>
                            <Setter TargetName="TextPresenter" Property="Content" Value="{Binding OnContent, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="TextPresenter" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="TextPresenter" Property="Margin" Value="10,0,5,0"/>
                        </Trigger>
                        
                        <!-- 鼠标悬停效果 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        
                        <!-- 禁用状态 -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.5"/>
                        </Trigger>
                        
                        <!-- 尺寸设置 -->
                        <Trigger Property="Size" Value="{x:Static controls:SwitchSize.Small}">
                            <Setter Property="Width" Value="40"/>
                            <Setter Property="Height" Value="20"/>
                            <Setter TargetName="Thumb" Property="Width" Value="16"/>
                            <Setter TargetName="Thumb" Property="Height" Value="16"/>
                            <Setter TargetName="Thumb" Property="CornerRadius" Value="8"/>
                        </Trigger>
                        <Trigger Property="Size" Value="{x:Static controls:SwitchSize.Medium}">
                            <Setter Property="Width" Value="50"/>
                            <Setter Property="Height" Value="24"/>
                            <Setter TargetName="Thumb" Property="Width" Value="20"/>
                            <Setter TargetName="Thumb" Property="Height" Value="20"/>
                            <Setter TargetName="Thumb" Property="CornerRadius" Value="10"/>
                        </Trigger>
                        <Trigger Property="Size" Value="{x:Static controls:SwitchSize.Large}">
                            <Setter Property="Width" Value="60"/>
                            <Setter Property="Height" Value="28"/>
                            <Setter TargetName="Thumb" Property="Width" Value="24"/>
                            <Setter TargetName="Thumb" Property="Height" Value="24"/>
                            <Setter TargetName="Thumb" Property="CornerRadius" Value="12"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>