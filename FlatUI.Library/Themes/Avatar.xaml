<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Avatar 头像控件样式 -->
    
    <!-- 默认圆形头像样式 -->
    <Style x:Key="DefaultAvatarStyle" TargetType="{x:Type controls:FlatAvatar}">
        <Setter Property="Width" Value="{Binding Size, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="Height" Value="{Binding Size, RelativeSource={RelativeSource Self}}"/>
        <Setter Property="AvatarBackground" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="AvatarForeground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Shape" Value="Circle"/>
        <Setter Property="ShowBorder" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlatAvatar}">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <!-- 背景容器 -->
                        <Border x:Name="border"
                                Background="{TemplateBinding AvatarBackground}"
                                CornerRadius="{TemplateBinding Shape, Converter={StaticResource ShapeToCornerRadiusConverter}}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- 内容区域 -->
                        <Grid>
                            <!-- 图片模式 -->
                            <Image x:Name="imgAvatar"
                                   Source="{TemplateBinding Source}"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed"
                                   Clip="{Binding ElementName=border, Path=ActualWidth, Converter={StaticResource WidthToClipConverter}}"/>
                            
                            <!-- 图标模式 -->
                            <Path x:Name="pathIcon"
                                  Data="{TemplateBinding Icon}"
                                  Fill="{TemplateBinding AvatarForeground}"
                                  Stretch="Uniform"
                                  Width="24" Height="24"
                                  Visibility="Collapsed"/>
                            
                            <!-- 文字模式 -->
                            <TextBlock x:Name="txtAvatar"
                                       Text="{TemplateBinding Text}"
                                       Foreground="{TemplateBinding AvatarForeground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Visible"/>
                        </Grid>
                        
                        <!-- 边框 -->
                        <Border x:Name="borderBorder"
                                BorderBrush="{TemplateBinding BorderColor}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding Shape, Converter={StaticResource ShapeToCornerRadiusConverter}}"
                                Visibility="Collapsed"/>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- 显示模式切换 -->
                        <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}, Converter={StaticResource NullToBoolConverter}}" Value="True">
                            <Setter TargetName="imgAvatar" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="txtAvatar" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        
                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource Self}, Converter={StaticResource NullToBoolConverter}}" Value="True">
                            <Setter TargetName="pathIcon" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="txtAvatar" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        
                        <!-- 形状切换 -->
                        <Trigger Property="Shape" Value="RoundedSquare">
                            <Setter TargetName="border" Property="CornerRadius" Value="8"/>
                            <Setter TargetName="borderBorder" Property="CornerRadius" Value="8"/>
                        </Trigger>
                        
                        <!-- 边框显示 -->
                        <Trigger Property="ShowBorder" Value="True">
                            <Setter TargetName="borderBorder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 小尺寸头像 -->
    <Style x:Key="SmallAvatarStyle" TargetType="{x:Type controls:FlatAvatar}" BasedOn="{StaticResource DefaultAvatarStyle}">
        <Setter Property="Size" Value="32"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    
    <!-- 中尺寸头像 -->
    <Style x:Key="MediumAvatarStyle" TargetType="{x:Type controls:FlatAvatar}" BasedOn="{StaticResource DefaultAvatarStyle}">
        <Setter Property="Size" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- 大尺寸头像 -->
    <Style x:Key="LargeAvatarStyle" TargetType="{x:Type controls:FlatAvatar}" BasedOn="{StaticResource DefaultAvatarStyle}">
        <Setter Property="Size" Value="48"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <!-- 超大尺寸头像 -->
    <Style x:Key="ExtraLargeAvatarStyle" TargetType="{x:Type controls:FlatAvatar}" BasedOn="{StaticResource DefaultAvatarStyle}">
        <Setter Property="Size" Value="64"/>
        <Setter Property="FontSize" Value="20"/>
    </Style>
    
    <!-- 默认样式 -->
    <Style TargetType="{x:Type controls:FlatAvatar}" BasedOn="{StaticResource DefaultAvatarStyle}"/>

</ResourceDictionary>
