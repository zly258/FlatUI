<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml"/>
        <ResourceDictionary Source="Fonts.xaml"/>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Icon 样式 -->
    <Style TargetType="{x:Type controls:FlatIcon}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlatIcon}">
                    <Grid x:Name="RootGrid">
                        <Viewbox Stretch="Uniform">
                            <Path x:Name="IconPath"
                                  Data="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IconData}"
                                  Fill="{TemplateBinding IconColor}"
                                  Stretch="Uniform"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="{TemplateBinding Rotation}"/>
                                </Path.RenderTransform>
                            </Path>
                        </Viewbox>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- 旋转动画 -->
                        <Trigger Property="IsSpinning" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="IconPath"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                         From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        
                        <!-- 尺寸设置 -->
                        <Trigger Property="IconSize" Value="{x:Static controls:IconSize.Small}">
                            <Setter Property="Width" Value="16"/>
                            <Setter Property="Height" Value="16"/>
                        </Trigger>
                        <Trigger Property="IconSize" Value="{x:Static controls:IconSize.Medium}">
                            <Setter Property="Width" Value="24"/>
                            <Setter Property="Height" Value="24"/>
                        </Trigger>
                        <Trigger Property="IconSize" Value="{x:Static controls:IconSize.Large}">
                            <Setter Property="Width" Value="32"/>
                            <Setter Property="Height" Value="32"/>
                        </Trigger>
                        <Trigger Property="IconSize" Value="{x:Static controls:IconSize.ExtraLarge}">
                            <Setter Property="Width" Value="48"/>
                            <Setter Property="Height" Value="48"/>
                        </Trigger>
                        
                        <!-- 默认图标颜色 -->
                        <Trigger Property="IconColor" Value="{x:Null}">
                            <Setter TargetName="IconPath" Property="Fill" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 图标数据转换器 -->
    <controls:IconDataConverter x:Key="IconDataConverter"/>

</ResourceDictionary>