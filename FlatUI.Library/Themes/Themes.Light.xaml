<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#007ACC</Color>
    <Color x:Key="PrimaryHoverColor">#1C97EA</Color>
    <Color x:Key="PrimaryPressedColor">#005A9E</Color>
    
    <!-- Neutral Colors -->
    <Color x:Key="BackgroundColor">#FFFFFF</Color>
    <Color x:Key="RegionColor">#F3F3F3</Color>
    <Color x:Key="BorderColor">#CCCCCC</Color>
    <Color x:Key="BorderHoverColor">#007ACC</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextColor">#333333</Color>
    <Color x:Key="TextSecondaryColor">#666666</Color>
    <Color x:Key="TextDisabledColor">#A6A6A6</Color>
    <Color x:Key="WhiteTextColor">#FFFFFF</Color>
</ResourceDictionary>