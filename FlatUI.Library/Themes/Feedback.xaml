<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml"/>
        <ResourceDictionary Source="Fonts.xaml"/>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Spinner Style -->
    <Style x:Key="FlatSpinner" TargetType="Control">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Grid>
                        <!-- 现代圆形加载动画 -->
                        <Ellipse x:Name="BackgroundCircle" 
                                 Stroke="{StaticResource BorderBrush}" 
                                 StrokeThickness="2" 
                                 Opacity="0.3"/>
                        
                        <!-- 主加载弧线 -->
                        <Path x:Name="MainArc" 
                              Stroke="{StaticResource PrimaryBrush}" 
                              StrokeThickness="3" 
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 16,2 A 14,14 0 0 1 30,16" 
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" 
                                                             From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                        
                        <!-- 辅助加载弧线（反向旋转） -->
                        <Path x:Name="SecondaryArc" 
                              Stroke="{StaticResource PrimaryLightBrush}" 
                              StrokeThickness="2" 
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 16,2 A 14,14 0 0 0 2,16" 
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" 
                                                             From="0" To="-360" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 小尺寸Spinner -->
    <Style x:Key="FlatSpinnerSmall" TargetType="Control" BasedOn="{StaticResource FlatSpinner}">
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
    </Style>

    <!-- 大尺寸Spinner -->
    <Style x:Key="FlatSpinnerLarge" TargetType="Control" BasedOn="{StaticResource FlatSpinner}">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
    </Style>

    <!-- 点状Spinner -->
    <Style x:Key="FlatSpinnerDots" TargetType="Control">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Grid>
                        <!-- 三个点状加载动画 -->
                        <Ellipse x:Name="Dot1" 
                                 Fill="{StaticResource PrimaryBrush}" 
                                 Width="4" Height="4" 
                                 HorizontalAlignment="Center" 
                                 VerticalAlignment="Top" 
                                 Margin="0,4,0,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                             From="0.3" To="1" Duration="0:0:0.6" 
                                                             AutoReverse="True" BeginTime="0:0:0"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        
                        <Ellipse x:Name="Dot2" 
                                 Fill="{StaticResource PrimaryBrush}" 
                                 Width="4" Height="4" 
                                 HorizontalAlignment="Center" 
                                 VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                             From="0.3" To="1" Duration="0:0:0.6" 
                                                             AutoReverse="True" BeginTime="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        
                        <Ellipse x:Name="Dot3" 
                                 Fill="{StaticResource PrimaryBrush}" 
                                 Width="4" Height="4" 
                                 HorizontalAlignment="Center" 
                                 VerticalAlignment="Bottom" 
                                 Margin="0,0,0,4">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                             From="0.3" To="1" Duration="0:0:0.6" 
                                                             AutoReverse="True" BeginTime="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- EmptyState Style -->
    <Style x:Key="FlatEmptyState" TargetType="HeaderedContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="HeaderedContentControl">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 12h-2v-2h2v2zm0-4h-2V6h2v4z"
                              Fill="{StaticResource BorderBrush}" Width="64" Height="64" Stretch="Uniform" Margin="0,0,0,10"/>
                        <ContentPresenter ContentSource="Header" TextBlock.Foreground="{StaticResource TextSecondaryBrush}" 
                                          TextBlock.FontSize="{StaticResource FontSizeMedium}" HorizontalAlignment="Center"/>
                        <ContentPresenter ContentSource="Content" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Skeleton Style -->
    <Style x:Key="FlatSkeleton" TargetType="Control">
        <Setter Property="Background" Value="{StaticResource RegionBrush}"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <Border x:Name="PART_Shimmer" Background="{StaticResource BackgroundBrush}" Opacity="0.5" Width="100" HorizontalAlignment="Left">
                            <Border.RenderTransform>
                                <TranslateTransform X="-100"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                             From="-100" To="300" Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>