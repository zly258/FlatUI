<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml"/>
        <ResourceDictionary Source="Fonts.xaml"/>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- 拖拽上传控件样式 -->
    <Style TargetType="controls:FlatDragDropUpload">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="MinHeight" Value="120"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:FlatDragDropUpload">
                    <Grid x:Name="Root">
                        
                        <!-- 拖拽区域 -->
                        <Border x:Name="DragArea"
                                Background="{TemplateBinding DragAreaBackground}"
                                BorderBrush="{TemplateBinding DragAreaBorderBrush}"
                                BorderThickness="{TemplateBinding DragAreaBorderThickness}"
                                CornerRadius="{TemplateBinding DragAreaCornerRadius}"
                                Visibility="{Binding ShowDragArea, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}">
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 图标 -->
                                <Path x:Name="UploadIcon"
                                      Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"
                                      Fill="{TemplateBinding Foreground}"
                                      Width="48"
                                      Height="48"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,10"
                                      Opacity="0.6"/>
                                
                                <!-- 提示文本 -->
                                <TextBlock x:Name="HintText"
                                           Grid.Row="1"
                                           Text="{TemplateBinding DragHintText}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,0,0,5"/>
                                
                                <!-- 拖拽中提示文本 -->
                                <TextBlock x:Name="DragOverHintText"
                                           Grid.Row="1"
                                           Text="{TemplateBinding DragOverHintText}"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,0,0,5"
                                           Visibility="Collapsed"/>
                                
                                <!-- 文件类型限制提示 -->
                                <TextBlock x:Name="FileTypeHint"
                                           Grid.Row="2"
                                           Text="{Binding AllowedFileTypes, RelativeSource={RelativeSource TemplatedParent}, StringFormat='支持的文件类型: {0}'}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           TextAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <!-- 自定义内容 -->
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="{TemplateBinding Padding}"/>
                        
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        
                        <!-- 拖拽中状态 -->
                        <Trigger Property="IsDragOver" Value="True">
                            <Setter TargetName="DragArea" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                            <Setter TargetName="DragArea" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="DragArea" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="HintText" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="DragOverHintText" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="UploadIcon" Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="UploadIcon" Property="Opacity" Value="1"/>
                        </Trigger>
                        
                        <!-- 默认拖拽区域背景 -->
                        <Trigger Property="DragAreaBackground" Value="{x:Null}">
                            <Setter TargetName="DragArea" Property="Background" Value="{StaticResource RegionBrush}"/>
                        </Trigger>
                        
                        <!-- 默认拖拽区域边框 -->
                        <Trigger Property="DragAreaBorderBrush" Value="{x:Null}">
                            <Setter TargetName="DragArea" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        </Trigger>
                        
                        <!-- 鼠标悬停效果 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DragArea" Property="Background" Value="{StaticResource RegionHoverBrush}"/>
                            <Setter TargetName="DragArea" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>