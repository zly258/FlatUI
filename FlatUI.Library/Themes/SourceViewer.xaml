<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">
    
    <Style TargetType="{x:Type controls:FlatSourceViewer}">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FlatSourceViewer}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 标题栏 -->
                            <Border Grid.Row="0" 
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="4,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0"
                                               Text="源码查看"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="10,8"/>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                                        <Button x:Name="CopyButton"
                                                Content="复制"
                                                Style="{DynamicResource FlatButton}"
                                                Margin="0,0,5,0"
                                                Padding="8,4"/>
                                        <Button x:Name="CloseButton"
                                                Content="关闭"
                                                Style="{DynamicResource FlatButton}"
                                                Padding="8,4"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- 源码内容 -->
                            <Border Grid.Row="1" 
                                    Background="{DynamicResource BackgroundBrush}"
                                    Margin="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="SourceTextBlock"
                                               Text="{TemplateBinding SourceCode}"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </Border>
                            
                            <!-- 状态栏 -->
                            <Border Grid.Row="2" 
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    CornerRadius="0,0,4,4">
                                <TextBlock Text="{Binding SourceLanguage, RelativeSource={RelativeSource TemplatedParent}, StringFormat='语言: {0}'}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="10,4"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="CopyButton" Property="IsPressed" Value="True">
                            <Setter TargetName="CopyButton" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="CopyButton" Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
                        </Trigger>
                        
                        <Trigger SourceName="CloseButton" Property="IsPressed" Value="True">
                            <Setter TargetName="CloseButton" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                            <Setter TargetName="CloseButton" Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>