<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Brushes.xaml"/>
        <ResourceDictionary Source="Fonts.xaml"/>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- 进度条控件样式 -->
    <Style TargetType="controls:ProgressBar">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinHeight" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ProgressBar">
                    <Grid x:Name="Root">
                        
                        <!-- 线性进度条 -->
                        <Grid x:Name="LinearProgress" Visibility="{Binding ProgressType, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter={x:Static controls:ProgressType.Linear}}">
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Height="{TemplateBinding ProgressHeight}"
                                    VerticalAlignment="Center"/>
                            
                            <Border x:Name="Progress"
                                    Background="{TemplateBinding ProgressBrush}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Height="{TemplateBinding ProgressHeight}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                        <Binding Path="ActualWidth" ElementName="Track"/>
                                        <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    </MultiBinding>
                                </Border.Width>
                                
                                <!-- 条纹动画 -->
                                <Border.Resources>
                                    <Storyboard x:Key="StripedAnimation" RepeatBehavior="Forever">
                                        <DoubleAnimation From="-100" To="100" Duration="0:0:1" Storyboard.TargetName="Stripes" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"/>
                                    </Storyboard>
                                </Border.Resources>
                                
                                <Border x:Name="Stripes" Visibility="{Binding IsStriped, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.Background>
                                        <DrawingBrush Viewport="0,0,10,10" ViewportUnits="Absolute" TileMode="Tile">
                                            <DrawingBrush.Drawing>
                                                <DrawingGroup>
                                                    <GeometryDrawing Brush="#40FFFFFF" Geometry="M0,0 L10,0 10,5 0,5 Z"/>
                                                    <GeometryDrawing Brush="#40FFFFFF" Geometry="M0,5 L10,5 10,10 0,10 Z"/>
                                                </DrawingGroup>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Border.Background>
                                    <Border.RenderTransform>
                                        <TranslateTransform/>
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            
                            <!-- 百分比文本 -->
                            <TextBlock x:Name="PercentageText"
                                       Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Converter={StaticResource ProgressPercentageConverter}}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowPercentage, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                        
                        <!-- 环形进度条 -->
                        <Grid x:Name="CircularProgress" Visibility="{Binding ProgressType, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter={x:Static controls:ProgressType.Circular}}">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="100" Height="100">
                                    <Ellipse x:Name="CircularTrack"
                                             Stroke="{TemplateBinding BorderBrush}"
                                             StrokeThickness="8"
                                             Fill="Transparent"/>
                                    
                                    <Path x:Name="CircularProgressPath"
                                          Stroke="{TemplateBinding ProgressBrush}"
                                          StrokeThickness="8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure StartPoint="50,10">
                                                    <ArcSegment x:Name="CircularArc"
                                                               Size="40,40"
                                                               SweepDirection="Clockwise"
                                                               IsLargeArc="False"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    
                                    <!-- 环形进度条文本 -->
                                    <TextBlock x:Name="CircularPercentageText"
                                               Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Converter={StaticResource ProgressPercentageConverter}}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding ShowPercentage, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Viewbox>
                        </Grid>
                        
                        <!-- 半环形进度条 -->
                        <Grid x:Name="SemiCircularProgress" Visibility="{Binding ProgressType, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter={x:Static controls:ProgressType.SemiCircular}}">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="100" Height="50">
                                    <Path x:Name="SemiCircularTrack"
                                          Stroke="{TemplateBinding BorderBrush}"
                                          StrokeThickness="8"
                                          Fill="Transparent">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure StartPoint="10,40">
                                                    <ArcSegment Point="90,40"
                                                               Size="40,40"
                                                               SweepDirection="Clockwise"
                                                               IsLargeArc="True"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    
                                    <Path x:Name="SemiCircularProgressPath"
                                          Stroke="{TemplateBinding ProgressBrush}"
                                          StrokeThickness="8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent">
                                        <Path.Data>
                                            <PathGeometry>
                                                <PathFigure StartPoint="10,40">
                                                    <ArcSegment x:Name="SemiCircularArc"
                                                               Size="40,40"
                                                               SweepDirection="Clockwise"
                                                               IsLargeArc="False"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    
                                    <!-- 半环形进度条文本 -->
                                    <TextBlock x:Name="SemiCircularPercentageText"
                                               Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Converter={StaticResource ProgressPercentageConverter}}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,10"
                                               Visibility="{Binding ShowPercentage, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Viewbox>
                        </Grid>
                        
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        
                        <!-- 状态颜色 -->
                        <Trigger Property="Status" Value="{x:Static controls:ProgressStatus.Success}">
                            <Setter TargetName="Progress" Property="Background" Value="{StaticResource SuccessBrush}"/>
                            <Setter TargetName="CircularProgressPath" Property="Stroke" Value="{StaticResource SuccessBrush}"/>
                            <Setter TargetName="SemiCircularProgressPath" Property="Stroke" Value="{StaticResource SuccessBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="{x:Static controls:ProgressStatus.Warning}">
                            <Setter TargetName="Progress" Property="Background" Value="{StaticResource WarningBrush}"/>
                            <Setter TargetName="CircularProgressPath" Property="Stroke" Value="{StaticResource WarningBrush}"/>
                            <Setter TargetName="SemiCircularProgressPath" Property="Stroke" Value="{StaticResource WarningBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="{x:Static controls:ProgressStatus.Error}">
                            <Setter TargetName="Progress" Property="Background" Value="{StaticResource ErrorBrush}"/>
                            <Setter TargetName="CircularProgressPath" Property="Stroke" Value="{StaticResource ErrorBrush}"/>
                            <Setter TargetName="SemiCircularProgressPath" Property="Stroke" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="Status" Value="{x:Static controls:ProgressStatus.Info}">
                            <Setter TargetName="Progress" Property="Background" Value="{StaticResource InfoBrush}"/>
                            <Setter TargetName="CircularProgressPath" Property="Stroke" Value="{StaticResource InfoBrush}"/>
                            <Setter TargetName="SemiCircularProgressPath" Property="Stroke" Value="{StaticResource InfoBrush}"/>
                        </Trigger>
                        
                        <!-- 默认进度条颜色 -->
                        <Trigger Property="ProgressBrush" Value="{x:Null}">
                            <Setter TargetName="Progress" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="CircularProgressPath" Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="SemiCircularProgressPath" Property="Stroke" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        
                        <!-- 动画效果 -->
                        <Trigger Property="IsAnimated" Value="True">
                            <Setter TargetName="Stripes" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>