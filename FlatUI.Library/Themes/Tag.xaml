<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FlatUI.Library.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Shared.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Tag 标签控件样式 -->
    
    <Style x:Key="DefaultTagStyle" TargetType="{x:Type controls:Tag}">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="TagBackground" Value="{DynamicResource RegionBrush}"/>
        <Setter Property="TagForeground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderColor" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TagSize" Value="Medium"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Tag}">
                    <Border x:Name="border"
                            Background="{TemplateBinding TagBackground}"
                            BorderBrush="{TemplateBinding BorderColor}"
                            BorderThickness="1"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        
                        <StackPanel Orientation="Horizontal" 
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            
                            <!-- 图标 -->
                            <Path x:Name="iconPath"
                                  Data="{TemplateBinding Icon}"
                                  Fill="{TemplateBinding TagForeground}"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  Margin="0,0,6,0"
                                  Visibility="Collapsed"/>
                            
                            <!-- 内容显示模式 -->
                            <ContentPresenter x:Name="contentPresenter"
                                              VerticalAlignment="Center"
                                              Visibility="{TemplateBinding Content, Converter={StaticResource NullToVisibilityConverter}}"/>
                            
                            <!-- 编辑模式 -->
                            <TextBox x:Name="editTextBox"
                                     Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Content, Mode=TwoWay}"
                                     FontSize="{TemplateBinding FontSize}"
                                     Foreground="{TemplateBinding TagForeground}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     Margin="0"
                                     Visibility="Collapsed"
                                     MinWidth="50"/>
                            
                            <!-- 关闭按钮 -->
                            <Button x:Name="closeButton"
                                    Content="×"
                                    Foreground="{TemplateBinding TagForeground}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="16"
                                    Padding="4,0,0,0"
                                    Margin="6,0,0,0"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" Cursor="Hand">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <ControlTemplate.Triggers>
                        <!-- 图标显示 -->
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="iconPath" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="iconPath" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        
                        <!-- 编辑模式 -->
                        <Trigger Property="IsEditing" Value="True">
                            <Setter TargetName="contentPresenter" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="editTextBox" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        
                        <!-- 关闭按钮显示 -->
                        <Trigger Property="Closable" Value="True">
                            <Setter TargetName="closeButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        
                        <!-- 选中状态 -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        
                        <!-- 尺寸切换 -->
                        <Trigger Property="TagSize" Value="Small">
                            <Setter Property="Padding" Value="6,2"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Trigger>
                        
                        <Trigger Property="TagSize" Value="Large">
                            <Setter Property="Padding" Value="14,6"/>
                            <Setter Property="FontSize" Value="15"/>
                        </Trigger>
                        
                        <!-- 类型切换 -->
                        <Trigger Property="TagType" Value="Primary">
                            <Setter Property="TagBackground" Value="{DynamicResource PrimaryLightBrush}"/>
                            <Setter Property="TagForeground" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="BorderColor" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="TagType" Value="Success">
                            <Setter Property="TagBackground" Value="{DynamicResource SuccessLightBrush}"/>
                            <Setter Property="TagForeground" Value="{DynamicResource SuccessBrush}"/>
                            <Setter Property="BorderColor" Value="{DynamicResource SuccessBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="TagType" Value="Warning">
                            <Setter Property="TagBackground" Value="{DynamicResource WarningLightBrush}"/>
                            <Setter Property="TagForeground" Value="{DynamicResource WarningBrush}"/>
                            <Setter Property="BorderColor" Value="{DynamicResource WarningBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="TagType" Value="Error">
                            <Setter Property="TagBackground" Value="{DynamicResource ErrorLightBrush}"/>
                            <Setter Property="TagForeground" Value="{DynamicResource ErrorBrush}"/>
                            <Setter Property="BorderColor" Value="{DynamicResource ErrorBrush}"/>
                        </Trigger>
                        
                        <Trigger Property="TagType" Value="Info">
                            <Setter Property="TagBackground" Value="{DynamicResource InfoLightBrush}"/>
                            <Setter Property="TagForeground" Value="{DynamicResource InfoBrush}"/>
                            <Setter Property="BorderColor" Value="{DynamicResource InfoBrush}"/>
                        </Trigger>
                        
                        <!-- 鼠标悬停效果 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Selectable" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- 默认样式 -->
    <Style TargetType="{x:Type controls:Tag}" BasedOn="{StaticResource DefaultTagStyle}"/>

</ResourceDictionary>
