<flat:FlatWindow x:Class="FlatUI.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlatUI.Demo"
        xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
        mc:Ignorable="d"
        Title="Industrial Flat UI Demo" Height="700" Width="1100">
    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="_File">
                    <MenuItem Header="_New"/>
                    <MenuItem Header="_Open"/>
                    <MenuItem Header="_Save"/>
                    <Separator/>
                    <MenuItem Header="_Exit"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Cut"/>
                    <MenuItem Header="_Copy"/>
                    <MenuItem Header="_Paste"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Open Drawer" Click="OpenDrawer_Click"/>
                    <Separator/>
                    <MenuItem Header="Light Mode" Click="SetLightMode_Click"/>
                    <MenuItem Header="Dark Mode" Click="SetDarkMode_Click"/>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="_About"/>
                </MenuItem>
            </Menu>
            
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="User Profile" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Style="{StaticResource FlatAvatar}" Margin="0,0,10,0">
                            <TextBlock Text="AD"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Admin User" FontWeight="Bold"/>
                            <TextBlock Text="System Manager" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Navigation" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ListBox Style="{StaticResource SideNavStyle}" ItemContainerStyle="{StaticResource SideNavItemStyle}">
                        <ListBoxItem Content="Dashboard" IsSelected="True"/>
                        <ListBoxItem Content="Monitoring"/>
                        <ListBoxItem Content="History"/>
                        <ListBoxItem Content="Settings"/>
                    </ListBox>

                    <TextBlock Text="Status Badges" FontWeight="Bold" Margin="0,15,0,5"/>
                    <flat:StatusBadge Status="Success" Text="System Online" Margin="0,0,0,5"/>
                    <flat:StatusBadge Status="Warning" Text="High Temperature" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Quick Actions" FontWeight="Bold" Margin="0,15,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource IconButton}" Content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" ToolTip="Add Device"/>
                        <Button Style="{StaticResource IconButton}" Content="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" ToolTip="Edit Layout" Margin="5,0"/>
                        <Button Style="{StaticResource IconButton}" Content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" ToolTip="Delete Selected" Margin="5,0"/>
                    </StackPanel>
                </StackPanel>
                
                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <TabControl>
                        <TabItem Header="Data &amp; Paging">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource FlatSearchBox}" Width="250" HorizontalAlignment="Left" Tag="Filter devices..."/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <CheckBox Style="{StaticResource FlatSwitch}" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="Real-time Monitoring"/>
                                        <TextBlock Text="Auto-refresh" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <DataGrid Grid.Row="1" ItemsSource="{Binding Items}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTemplateColumn Header="Status" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <flat:StatusBadge Status="Success" Text="{Binding Status}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <flat:Pagination Grid.Row="2" Margin="0,15,0,0" TotalCount="100" PageSize="10" HorizontalAlignment="Right"/>
                            </Grid>
                        </TabItem>
                        
                        <TabItem Header="Cards &amp; Flow">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding CardItems}" Margin="10">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <HeaderedContentControl Header="{Binding Title}" Style="{StaticResource FlatCard}" Width="250" Margin="10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Description}" Margin="0,10" TextWrapping="Wrap"/>
                                                    <ProgressBar Value="{Binding Progress}" Margin="0,5"/>
                                                    <TextBlock Text="{Binding Progress, StringFormat={}{0}%}" FontSize="10" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </HeaderedContentControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Advanced Forms">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>
                                
                                <ScrollViewer Grid.Column="0">
                                    <flat:Form>
                                        <flat:FormItem Header="Device Name">
                                            <TextBox Text="Main Processor"/>
                                        </flat:FormItem>
                                        <flat:FormItem Header="Threshold">
                                            <flat:NumericUpDown Value="45.5" Minimum="0" Maximum="100" Increment="0.5"/>
                                        </flat:FormItem>
                                        <flat:FormItem Header="Selection">
                                            <flat:DropdownGrid ItemsSource="{Binding Items}"/>
                                        </flat:FormItem>
                                        <flat:FormItem Header="Actions">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Save" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                                                <Button Content="Notify" Click="Notify_Click" Margin="0,0,10,0"/>
                                                <Button Content="Test Dialog" Click="TestDialog_Click"/>
                                            </StackPanel>
                                        </flat:FormItem>
                                        <flat:FormItem Header="Feedback">
                                            <StackPanel>
                                                <Control Style="{StaticResource FlatSpinner}" Margin="0,0,0,20"/>
                                                <Control Style="{StaticResource FlatSkeleton}" Width="200" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </flat:FormItem>
                                    </flat:Form>
                                </ScrollViewer>

                                <Grid Grid.Column="1" Margin="10,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Properties (Grouped)" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <flat:PropertyGrid Grid.Row="1" Properties="{Binding PropertyList}"/>
                                </Grid>
                            </Grid>
                        </TabItem>
                        
                        <TabItem Header="Empty States">
                            <HeaderedContentControl Style="{StaticResource FlatEmptyState}" Header="No data available">
                                <Button Content="Initialize Database" Style="{StaticResource PrimaryButton}"/>
                            </HeaderedContentControl>
                        </TabItem>

                        <TabItem Header="Tree &amp; Media">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>
                                
                                <ScrollViewer Grid.Column="0">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Simple TreeGrid" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <TreeView Style="{StaticResource FlatTreeGrid}" ItemContainerStyle="{StaticResource TreeGridItem}">
                                            <TreeViewItem Header="Production Line A">
                                                <TreeViewItem Header="Conveyor 1 - Running"/>
                                                <TreeViewItem Header="Robot Arm 2 - Idle"/>
                                            </TreeViewItem>
                                            <TreeViewItem Header="Production Line B">
                                                <TreeViewItem Header="Conveyor 3 - Error"/>
                                            </TreeViewItem>
                                        </TreeView>
                                        
                                        <TextBlock Text="Simple Charts (Sparklines)" FontWeight="Bold" Margin="0,20,0,10"/>
                                        <ItemsControl Style="{StaticResource FlatSparkline}" ItemsSource="{Binding ChartData}"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Media &amp; Tools" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <Border Style="{StaticResource FlatImage}" Width="200" Height="150" HorizontalAlignment="Left" Margin="0,0,0,20">
                                        <TextBlock Text="Image Placeholder" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                    
                                    <TextBlock Text="QRCode Placeholder" FontSize="12" Margin="0,0,0,5"/>
                                    <Control Style="{StaticResource FlatQRCode}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="System &amp; Tools">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>
                                
                                <DockPanel Grid.Column="0" Margin="10">
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="Take Screenshot" Click="Screenshot_Click" Style="{DynamicResource PrimaryButton}" Margin="0,0,10,0"/>
                                        <Button Content="Crop Selection" Click="Crop_Click" Style="{DynamicResource FlatButton}" Margin="0,0,10,0"/>
                                        <Button Content="Show Floating Ball" Click="OpenFloatingWindow_Click" Style="{DynamicResource FlatButton}" Margin="0,0,10,0"/>
                                        <Button Content="Flash Tray" Click="FlashTray_Click" Style="{DynamicResource FlatButton}" Margin="0,0,10,0"/>
                                        <Button Content="Stop Flash" Click="StopFlash_Click" Style="{DynamicResource FlatButton}" Margin="0,0,10,0"/>
                                        <Button Content="System Notify" Click="ShowSystemNotify_Click" Style="{DynamicResource FlatButton}"/>
                                    </StackPanel>
                                    
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <flat:ImageCropper x:Name="Cropper" Source="{Binding ElementName=ScreenshotImage, Path=Source}"/>
                                        </Border>
                                        <Image x:Name="ScreenshotImage" Grid.Row="1" MaxHeight="200" Margin="0,10,0,0" Stretch="Uniform"/>
                                    </Grid>
                                </DockPanel>

                                <StackPanel Grid.Column="1" Margin="10">
                                    <TextBlock Text="Draggable List" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <ListBox ItemsSource="{Binding Items}" flat:DragDropHelper.IsEnabled="True" Height="200">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Padding="5"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="* Try dragging items to reorder" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,5,0,0"/>

                                    <TextBlock Text="LED Indicators" FontWeight="Bold" Margin="0,20,0,10"/>
                                    <flat:LedText Text="23:59:59" Margin="0,0,0,10"/>
                                    <flat:LedText Text="128.5 kW" LedColor="Orange"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </DockPanel>
        
        <flat:Drawer x:Name="SideDrawer" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" DrawerWidth="350">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Device Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <HeaderedContentControl Header="Live Metrics" Style="{StaticResource FlatCard}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Temperature: 42.5°C"/>
                                <TextBlock Text="Pressure: 1.2 MPa"/>
                            </StackPanel>
                        </HeaderedContentControl>
                        <TextBlock Text="System Logs" FontWeight="Bold" Margin="0,10"/>
                        <Border Background="{StaticResource RegionBrush}" Padding="10" CornerRadius="2">
                            <TextBlock Text="[14:22:01] Connection established\n[14:22:05] Data sync complete" FontFamily="Consolas" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                <Button Grid.Row="2" Content="Close" Click="CloseDrawer_Click" Margin="0,20,0,0"/>
            </Grid>
        </flat:Drawer>
    </Grid>
</flat:FlatWindow>
