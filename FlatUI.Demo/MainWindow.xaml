<flat:FlatWindow x:Class="FlatUI.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
        xmlns:views="clr-namespace:FlatUI.Demo.Views"
        xmlns:icons="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
        Title="Industrial Flat UI" Height="750" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SideColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                    <icons:FlatIcon IconType="Home" IconSize="Medium" IconColor="{DynamicResource PrimaryBrush}" Margin="0,0,10,0"/>
                    <TextBlock x:Name="LogoText" Text="FLAT UI" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                </StackPanel>

                <ListBox x:Name="NavList" Grid.Row="1" Style="{StaticResource SideNavStyle}" ItemContainerStyle="{StaticResource SideNavItemStyle}" SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Tag="仪表台" IsSelected="True">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="Home" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="仪表台"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="组件">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="Settings" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="组件"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="数据展示">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="List" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="数据展示"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="图表">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="Chart" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="图表"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="表格">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M22 10V6c0-1.11-.9-2-2-2H4c-1.1 0-1.99.89-1.99 2v4c1.1 0 1.99.9 1.99 2s-.89 2-2 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2zm-2-1.46c-1.19.69-2 1.99-2 3.46s.81 2.77 2 3.46V18H4v-2.54c1.19-.69 2-1.99 2-3.46 0-1.48-.8-2.77-1.99-3.46L4 6h16v2.54z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="表格"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="列表">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M2.5 4v3h5v12h3V7h5V4h-13zm19 5h-9v3h3v7h3v-7h3V9z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="列表"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="树形">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="树形"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="按钮">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="按钮"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="输入框">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="输入框"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="复选框">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M17.63 5.84C17.27 5.33 16.67 5 16 5L5 5.01C3.9 5.01 3 5.9 3 7v10c0 1.1.9 1.99 2 1.99L16 19c.67 0 1.27-.33 1.63-.84L22 12l-4.37-6.16z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="复选框"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="头像">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="头像"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="徽标">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="徽标"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="标签">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M20 4H4v2h16V4zm0 4H4l4 4v12h12V8l4-4zM6 18V6h12v12H6z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="标签"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="气泡">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="气泡"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="通知">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="通知"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="抽屉">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="抽屉"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="分页">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="分页"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="数字输入">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 15.5A3.5 3.5 0 0 1 8.5 12A3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5a3.5 3.5 0 0 1-3.5 3.5m7.43-2.53c.04-.32.07-.64.07-.97c0-.33-.03-.66-.07-1l2.11-1.63c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.31-.61-.22l-2.49 1c-.52-.39-1.06-.73-1.69-.98l-.37-2.65A.506.506 0 0 0 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.63.25-1.17.59-1.69.98l-2.49-1c-.22-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.04.34-.07.67-.07 1c0 .33.03.65.07.97l-2.11 1.66c-.19.15-.25.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1.01c.52.4 1.06.74 1.69.99l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.63-.26 1.17-.59 1.69-.99l2.49 1.01c.22.08.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.66z" Width="16" Height="16" Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" Stretch="Uniform" Margin="0,0,10,0"/>
                            <TextBlock Text="数字输入"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="下拉树">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="DropdownTree" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="下拉树"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="下拉表格">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="DropdownTable" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="下拉表格"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="设置">
                        <StackPanel Orientation="Horizontal">
                            <icons:FlatIcon IconType="Settings" IconSize="Small" Margin="0,0,10,0"/>
                            <TextBlock Text="设置"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <Button Grid.Row="2" Content="折叠" Style="{DynamicResource FlatButton}" Margin="10" Click="CollapseNav_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock x:Name="ViewTitle" Text="仪表台" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- 语言切换按钮 -->
                        <ComboBox x:Name="LanguageSelector" Width="120" Margin="0,0,15,0" 
                                  SelectionChanged="LanguageSelector_SelectionChanged"
                                  VerticalContentAlignment="Center">
                            <ComboBoxItem Content="简体中文" Tag="zh-CN"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                        </ComboBox>
                        
                        <Button Style="{StaticResource IconButton}" Content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z" ToolTip="Notifications" Click="Notify_Click"/>
                        <flat:Avatar x:Name="UserAvatar" Size="32" Text="AD" Margin="15,0,0,0" ToolTip="Admin User" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl x:Name="MainContent" Grid.Row="1">
                <!-- 仪表台 Content (Default) -->
                <views:DashboardView/>
            </ContentControl>
        </Grid>

        <!-- Global Drawer -->
        <flat:Drawer x:Name="SideDrawer" Grid.ColumnSpan="2" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" DrawerWidth="350">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Quick Actions" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                <ScrollViewer Grid.Row="1">
                    <StackPanel>
                        <Button Content="Take Screenshot" Click="Screenshot_Click" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,10"/>
                        <Button Content="Flash Tray Icon" Click="FlashTray_v2_Click" Style="{DynamicResource FlatButton}" Margin="0,0,0,10"/>
                        <Button Content="System Notification" Click="SystemNotify_v2_Click" Style="{DynamicResource FlatButton}" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
                <Button Grid.Row="2" Content="Close Drawer" Click="CloseDrawer_Click"/>
            </Grid>
        </flat:Drawer>
    </Grid>
</flat:FlatWindow>