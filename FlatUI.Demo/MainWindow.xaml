<Window x:Class="FlatUI.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlatUI.Demo"
        xmlns:vm="clr-namespace:FlatUI.Demo.ViewModels"
        xmlns:models="clr-namespace:FlatUI.Demo.Models"
        mc:Ignorable="d"
        Title="FlatUI - Ant Design 风格组件库" 
        Height="768" 
        Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" 
                Background="{DynamicResource PrimaryBrush}"
                Height="64"
                Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <TextBlock Text="FlatUI" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Demo" 
                               FontSize="14" 
                               FontWeight="Normal"
                               Foreground="White"
                               Opacity="0.8"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <Border Grid.Column="1" 
                        Background="White"
                        CornerRadius="4"
                        MaxWidth="400"
                        Height="32"
                        Margin="32,0"
                        VerticalAlignment="Center"
                        Padding="8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Path Grid.Column="0"
                              Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              VerticalAlignment="Center"/>
                        
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 Padding="8,0,0,0"
                                 FontSize="14"
                                 Foreground="{DynamicResource TextBrush}"/>
                    </Grid>
                </Border>
                
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Button Content="GitHub"
                            Style="{DynamicResource FlatButton}"
                            Foreground="White"
                            BorderBrush="White"
                            Margin="0,0,16,0"
                            Padding="12,6"/>
                    <Button Content="v1.0.0"
                            Style="{DynamicResource FlatButton}"
                            Foreground="White"
                            BorderBrush="White"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" 
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:NavigationItem">
                                <StackPanel>
                                    <Button Content="{Binding Title}"
                                            Command="{Binding DataContext.ExpandCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource FlatButton}"
                                            HorizontalContentAlignment="Left"
                                            Padding="16,12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextBrush}"
                                            FontWeight="SemiBold">
                                        <Button.ContentTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Path Grid.Column="0"
                                                          Data="{Binding Icon}"
                                                          Fill="{DynamicResource TextSecondaryBrush}"
                                                          Width="16"
                                                          Height="16"
                                                          Stretch="Uniform"
                                                          Margin="0,0,12,0"
                                                          Visibility="{Binding Icon, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               VerticalAlignment="Center"/>
                                                    
                                                    <Path Grid.Column="2"
                                                          Data="M7 10l5 5 5-5z"
                                                          Fill="{DynamicResource TextSecondaryBrush}"
                                                          Width="16"
                                                          Height="16"
                                                          Stretch="Uniform"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource BooleanToAngleConverter}}"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Grid>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                    
                                    <ItemsControl ItemsSource="{Binding Children}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="models:NavigationItem">
                                                <Button Content="{Binding Title}"
                                                        Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalContentAlignment="Left"
                                                        Padding="40,10"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{DynamicResource TextBrush}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            
            <ScrollViewer Grid.Column="1" 
                          VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding CurrentContent}"
                                Margin="48,32,48,48">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <ContentPresenter Content="{Binding}"/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
