<UserControl x:Class="FlatUI.Demo.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,20">
            <HeaderedContentControl Header="System Status" Style="{DynamicResource FlatCard}" Width="250" Margin="0,0,20,20">
                <StackPanel Margin="10">
                    <flat:StatusBadge Status="Success" Text="CPU: 12%" Margin="0,0,0,10"/>
                    <flat:StatusBadge Status="Warning" Text="RAM: 8.2 GB" Margin="0,0,0,10"/>
                    <flat:StatusBadge Status="Info" Text="Uptime: 4d 12h"/>
                </StackPanel>
            </HeaderedContentControl>

            <HeaderedContentControl Header="Quick Control" Style="{DynamicResource FlatCard}" Width="250" Margin="0,0,20,20">
                <StackPanel Margin="10">
                    <Button Content="Show Drawer" Style="{DynamicResource PrimaryButton}" Click="OpenDrawer_Click" Margin="0,0,0,10"/>
                    <Button Content="Test Dialog" Style="{DynamicResource FlatButton}" Click="TestDialog_Click"/>
                </StackPanel>
            </HeaderedContentControl>
        </WrapPanel>

        <HeaderedContentControl Grid.Row="1" Header="Live Feedback Components" Style="{DynamicResource FlatCard}">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel>
                    <TextBlock Text="Spinners" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Control Style="{StaticResource FlatSpinner}" Margin="0,0,20,0"/>
                        <Control Style="{StaticResource FlatSpinner}" Width="48" Height="48"/>
                    </StackPanel>

                    <TextBlock Text="Switches" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Style="{StaticResource FlatSwitch}" IsChecked="True" Margin="0,0,20,0"/>
                        <CheckBox Style="{StaticResource FlatSwitch}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Skeleton (Loading State)" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Control Style="{StaticResource FlatSkeleton}" Margin="0,0,0,10"/>
                    <Control Style="{StaticResource FlatSkeleton}" Width="200" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <Control Style="{StaticResource FlatSkeleton}" Height="100"/>
                </StackPanel>
            </Grid>
        </HeaderedContentControl>
    </Grid>
</UserControl>