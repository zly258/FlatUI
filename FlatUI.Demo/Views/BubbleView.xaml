<UserControl x:Class="FlatUI.Demo.Views.BubbleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="气泡卡片组件" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 左侧气泡 -->
            <HeaderedContentControl Header="左侧气泡（接收）" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <flat:Bubble Position="Left" SenderName="张三" AvatarText="张" Margin="0,0,0,15">
                        <TextBlock Text="你好，请问这个产品怎么使用？" TextWrapping="Wrap"/>
                    </flat:Bubble>
                    
                    <flat:Bubble Position="Left" SenderName="李四" AvatarText="李" BubbleBackground="{DynamicResource RegionBrush}">
                        <TextBlock Text="我遇到了一个问题，能帮我解决吗？" TextWrapping="Wrap"/>
                    </flat:Bubble>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 右侧气泡 -->
            <HeaderedContentControl Header="右侧气泡（发送）" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <flat:Bubble Position="Right" SenderName="我" AvatarText="我" BubbleBackground="{DynamicResource PrimaryLightBrush}" Margin="0,0,0,15">
                        <TextBlock Text="您好！很高兴为您服务，请问有什么可以帮助您的？" TextWrapping="Wrap"/>
                    </flat:Bubble>
                    
                    <flat:Bubble Position="Right" SenderName="我" AvatarText="我" BubbleBackground="{DynamicResource SuccessLightBrush}">
                        <TextBlock Text="好的，我明白了。这个问题很好解决。" TextWrapping="Wrap"/>
                    </flat:Bubble>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 简单气泡 -->
            <HeaderedContentControl Header="简单气泡（无头像和信息）" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <flat:Bubble Position="Left" ShowAvatar="False" ShowSenderName="False" ShowTimestamp="False" Margin="0,0,0,15">
                        <TextBlock Text="这是一条简单的消息，没有头像和发送者信息。" TextWrapping="Wrap"/>
                    </flat:Bubble>
                    
                    <flat:Bubble Position="Right" ShowAvatar="False" ShowSenderName="False" ShowTimestamp="False" BubbleBackground="{DynamicResource PrimaryLightBrush}">
                        <TextBlock Text="我也是简单气泡，适合简洁的对话场景。" TextWrapping="Wrap"/>
                    </flat:Bubble>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 聊天对话示例 -->
            <HeaderedContentControl Header="聊天对话示例" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="15" MinHeight="400">
                    <ScrollViewer>
                        <StackPanel>
                            <!-- 客服消息 -->
                            <flat:Bubble Position="Left" SenderName="客服小王" AvatarText="客" Timestamp="{x:Static sys:DateTime.Now}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="欢迎光临！请问有什么可以帮您？" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,5,0,0">
                                        <flat:Tag Content="在线" TagType="Success" TagSize="Small"/>
                                        <flat:Tag Content="客服" TagType="Primary" TagSize="Small" Margin="5,0,0,0"/>
                                    </WrapPanel>
                                </StackPanel>
                            </flat:Bubble>
                            
                            <!-- 用户消息 -->
                            <flat:Bubble Position="Right" SenderName="用户" AvatarText="用" BubbleBackground="{DynamicResource PrimaryLightBrush}" Margin="0,0,0,10">
                                <TextBlock Text="我想了解一下这款产品的价格和功能" TextWrapping="Wrap"/>
                            </flat:Bubble>
                            
                            <!-- 客服回复 -->
                            <flat:Bubble Position="Left" SenderName="客服小王" AvatarText="客" Timestamp="{x:Static sys:DateTime.Now}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="好的，这款产品的价格是：" TextWrapping="Wrap"/>
                                    <TextBlock Text="¥ 199.00" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryBrush}" Margin="0,5,0,10"/>
                                    <TextBlock Text="主要功能包括：A、B、C、D 四个模块，支持..." TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,5,0,0">
                                        <flat:Badge DisplayText="热销" BadgeSize="Small" Margin="0,0,10,0"/>
                                        <flat:Tag Content="包邮" TagType="Success" TagSize="Small"/>
                                    </WrapPanel>
                                </StackPanel>
                            </flat:Bubble>
                            
                            <!-- 用户回复 -->
                            <flat:Bubble Position="Right" SenderName="用户" AvatarText="用" BubbleBackground="{DynamicResource PrimaryLightBrush}">
                                <TextBlock Text="听起来不错，我可以试用一下吗？" TextWrapping="Wrap"/>
                            </flat:Bubble>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
