<UserControl x:Class="FlatUI.Demo.Views.GridExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Grid 栅格"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="24 栅格系统"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础栅格" Description="使用 Grid 定义 24 列布局。">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="0,0,4,0">
                        <TextBlock Text="Col-6" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="4,0,4,0">
                        <TextBlock Text="Col-6" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="4,0,4,0">
                        <TextBlock Text="Col-6" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="3" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="4,0,0,0">
                        <TextBlock Text="Col-6" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="区块间隔" Description="栅格常常需要和间隔进行配合。">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="0,0,8,0">
                            <TextBlock Text="Col-8" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="8,0,8,0">
                            <TextBlock Text="Col-8" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="8,0,0,0">
                            <TextBlock Text="Col-8" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="0,0,8,0">
                            <TextBlock Text="Col-16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="8,0,0,0">
                            <TextBlock Text="Col-8" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="左右偏移" Description="列偏移。">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="2" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="0,0,4,0">
                        <TextBlock Text="Col-4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="3" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="4,0,4,0">
                        <TextBlock Text="Col-4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="4,0,4,0">
                        <TextBlock Text="Col-4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="5" Background="{DynamicResource PrimaryBrush}" Height="32" Margin="4,0,0,0">
                        <TextBlock Text="Col-4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
