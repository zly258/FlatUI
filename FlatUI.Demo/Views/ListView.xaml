<UserControl x:Class="FlatUI.Demo.Views.ListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <ScrollViewer Margin="20">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="列表" FontSize="24" FontWeight="Bold"/>
                <Button Content="查看源码" Style="{DynamicResource FlatButton}" Click="ViewSource_Click" Margin="20,0,0,0"/>
            </StackPanel>
            
            <!-- Basic List -->
            <HeaderedContentControl Header="基础列表" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <ListBox Style="{DynamicResource FlatListBox}" Width="400">
                        <ListBoxItem Content="项目 1"/>
                        <ListBoxItem Content="项目 2"/>
                        <ListBoxItem Content="项目 3"/>
                        <ListBoxItem Content="项目 4"/>
                    </ListBox>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- List with CheckBox -->
            <HeaderedContentControl Header="带复选框的列表" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <ListBox x:Name="CheckBoxList" Style="{DynamicResource FlatListBox}" Width="400">
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="False" Margin="0,0,10,0"/>
                                <TextBlock Text="项目 1"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="True" Margin="0,0,10,0"/>
                                <TextBlock Text="项目 2"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="False" Margin="0,0,10,0"/>
                                <TextBlock Text="项目 3"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- ListCard Style -->
            <HeaderedContentControl Header="列表卡片样式" Style="{DynamicResource FlatCard}">
                <StackPanel Margin="10" Width="500">
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <flat:Avatar Size="40" Text="张三" Background="{DynamicResource PrimaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="张三" FontWeight="Bold"/>
                                <TextBlock Text="zhangsan@example.com" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="查看" Style="{DynamicResource FlatButton}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <flat:Avatar Size="40" Text="李四" Background="{DynamicResource SuccessBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="李四" FontWeight="Bold"/>
                                <TextBlock Text="lisi@example.com" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="查看" Style="{DynamicResource FlatButton}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="4" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <flat:Avatar Size="40" Text="王五" Background="{DynamicResource WarningBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="王五" FontWeight="Bold"/>
                                <TextBlock Text="wangwu@example.com" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="查看" Style="{DynamicResource FlatButton}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
