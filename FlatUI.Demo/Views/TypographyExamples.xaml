<UserControl x:Class="FlatUI.Demo.Views.TypographyExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Typography 排版"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="文本排版组件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="文本样式" Description="不同级别的文本样式。">
                <StackPanel>
                    <TextBlock Text="h1. Ant Design" FontSize="38" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="h2. Ant Design" FontSize="30" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="h3. Ant Design" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="h4. Ant Design" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="h5. Ant Design" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TextBlock Text="Default text" FontSize="14" Margin="0,0,0,16"/>
                    <TextBlock Text="Secondary text" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Disabled text" FontSize="14" Foreground="{DynamicResource TextDisabledBrush}" Margin="0,0,0,16"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="文本对齐" Description="文本对齐方式。">
                <StackPanel>
                    <TextBlock Text="Left aligned text" FontSize="14" TextAlignment="Left" Margin="0,0,0,8"/>
                    <TextBlock Text="Center aligned text" FontSize="14" TextAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Right aligned text" FontSize="14" TextAlignment="Right" Margin="0,0,0,8"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="文本省略" Description="文本超出容器时显示省略号。">
                <StackPanel Width="300">
                    <TextBlock Text="This is a very long text that will be truncated with ellipsis when it exceeds the container width" 
                               FontSize="14" 
                               TextTrimming="CharacterEllipsis" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="This is a very long text that will be truncated with ellipsis when it exceeds the container width" 
                               FontSize="14" 
                               TextTrimming="WordEllipsis"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
