<UserControl x:Class="FlatUI.Demo.Views.InputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <ScrollViewer Margin="20">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="输入框" FontSize="24" FontWeight="Bold"/>
                <Button Content="查看源码" Style="{DynamicResource FlatButton}" Click="ViewSource_Click" Margin="20,0,0,0"/>
            </StackPanel>
            
            <!-- Text Input -->
            <HeaderedContentControl Header="文本输入" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBox Style="{DynamicResource FlatTextBox}" Width="300" HorizontalAlignment="Left" Margin="0,0,0,10"/>
                    <TextBox Style="{DynamicResource FlatTextBox}" Width="300" HorizontalAlignment="Left" Text="禁用状态" IsEnabled="False"/>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- TextArea -->
            <HeaderedContentControl Header="文本域" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBox Style="{DynamicResource FlatTextBox}" Width="400" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- Password -->
            <HeaderedContentControl Header="密码输入" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <PasswordBox Style="{DynamicResource FlatPasswordBox}" Width="300" HorizontalAlignment="Left"/>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- With Icons -->
            <HeaderedContentControl Header="带图标" Style="{DynamicResource FlatCard}">
                <StackPanel Margin="10">
                    <Grid Width="300" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBox Style="{DynamicResource FlatTextBox}" Padding="30,5,5,5"/>
                        <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" Fill="{DynamicResource TextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="300" HorizontalAlignment="Left">
                        <TextBox Style="{DynamicResource FlatTextBox}" Padding="5,5,30,5" TextAlignment="Right"/>
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Fill="{DynamicResource TextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </Grid>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
