<UserControl x:Class="FlatUI.Demo.Views.TagView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="标签组件" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 默认标签 -->
            <HeaderedContentControl Header="默认标签" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Tag Content="默认" Margin="0,0,10,0"/>
                        <flat:Tag Content="主要" TagType="Primary" Margin="0,0,10,0"/>
                        <flat:Tag Content="成功" TagType="Success" Margin="0,0,10,0"/>
                        <flat:Tag Content="警告" TagType="Warning" Margin="0,0,10,0"/>
                        <flat:Tag Content="错误" TagType="Error"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 可关闭标签 -->
            <HeaderedContentControl Header="可关闭标签" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Tag Content="可关闭" Closable="True" Margin="0,0,10,0"/>
                        <flat:Tag Content="主要" TagType="Primary" Closable="True" Margin="0,0,10,0"/>
                        <flat:Tag Content="成功" TagType="Success" Closable="True" Margin="0,0,10,0"/>
                        <flat:Tag Content="警告" TagType="Warning" Closable="True"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 可选择标签 -->
            <HeaderedContentControl Header="可选择标签" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Tag Content="选项 1" Selectable="True" IsSelected="True" Margin="0,0,10,0"/>
                        <flat:Tag Content="选项 2" Selectable="True" Margin="0,0,10,0"/>
                        <flat:Tag Content="选项 3" Selectable="True" Margin="0,0,10,0"/>
                        <flat:Tag Content="选项 4" Selectable="True"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 不同尺寸 -->
            <HeaderedContentControl Header="不同尺寸" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Tag Content="小标签" TagSize="Small" Margin="0,0,10,0"/>
                        <flat:Tag Content="中标签" Margin="0,0,10,0"/>
                        <flat:Tag Content="大标签" TagSize="Large"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 使用场景 -->
            <HeaderedContentControl Header="使用场景" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="文章分类：" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <flat:Tag Content="技术" TagType="Primary" Margin="0,0,5,0"/>
                                <flat:Tag Content="WPF" Margin="0,0,5,0"/>
                                <flat:Tag Content="UI 设计" TagType="Success" Margin="0,0,5,0"/>
                                <flat:Tag Content="教程" TagType="Info"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="商品标签：" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <flat:Tag Content="热销" TagType="Warning" Margin="0,0,5,0"/>
                                <flat:Tag Content="包邮" TagType="Success" Margin="0,0,5,0"/>
                                <flat:Tag Content="新品" TagType="Primary" Margin="0,0,5,0"/>
                                <flat:Tag Content="限时优惠" TagType="Error"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
