<UserControl x:Class="FlatUI.Demo.Views.StatusBadgeExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="StatusBadge 状态徽章"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="用于显示状态的徽章组件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础状态徽章。">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#52c41a" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="成功" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#1890ff" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="处理中" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#faad14" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="警告" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#ff4d4f" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="错误" Foreground="White" FontSize="12"/>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同状态" Description="不同颜色的状态徽章。">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#52c41a" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="Success" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#1890ff" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="Info" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#faad14" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="Warning" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#ff4d4f" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <TextBlock Text="Error" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#722ed1" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="Default" Foreground="White" FontSize="12"/>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="带图标" Description="带图标的状态徽章。">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#52c41a" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                  Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="成功" Foreground="White" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1890ff" CornerRadius="4" Padding="8,4" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                  Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="信息" Foreground="White" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#ff4d4f" CornerRadius="4" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                  Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="错误" Foreground="White" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
