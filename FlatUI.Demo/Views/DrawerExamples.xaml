<UserControl x:Class="FlatUI.Demo.Views.DrawerExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Drawer 抽屉"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="屏幕边缘滑出的浮层面板"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="点击按钮打开抽屉。">
                <StackPanel>
                    <Button Content="Open Left Drawer" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Open Right Drawer" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Open Top Drawer" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Open Bottom Drawer" Style="{DynamicResource PrimaryButton}"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="自定义位置" Description="自定义抽屉的位置和大小。">
                <StackPanel>
                    <Button Content="Open Drawer (25% width)" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Open Drawer (50% width)" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Open Drawer (75% width)" Style="{DynamicResource PrimaryButton}"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="多层抽屉" Description="在抽屉内打开新的抽屉。">
                <StackPanel>
                    <Button Content="Open Multi-level Drawer" Style="{DynamicResource PrimaryButton}"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
