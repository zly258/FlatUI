<UserControl x:Class="FlatUI.Demo.Views.AvatarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="头像组件" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 不同尺寸 -->
            <HeaderedContentControl Header="不同尺寸" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Avatar Size="32" Text="小" Margin="0,0,20,0"/>
                        <flat:Avatar Size="40" Text="中" Margin="0,0,20,0"/>
                        <flat:Avatar Size="64" Text="大" Margin="0,0,20,0"/>
                        <flat:Avatar Size="96" Text="超大"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 不同类型 -->
            <HeaderedContentControl Header="不同类型" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel Margin="0,0,0,20">
                        <flat:Avatar Size="50" Text="JD" Margin="0,0,20,0"/>
                        <flat:Avatar Size="50" Background="{StaticResource PrimaryBrush}" Text="WP" Foreground="White" Margin="0,0,20,0"/>
                        <flat:Avatar Size="50" Background="{StaticResource SuccessBrush}" Text="OK" Foreground="White" Margin="0,0,20,0"/>
                        <flat:Avatar Size="50" Background="{StaticResource WarningBrush}" Text="WA" Foreground="White"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 形状 -->
            <HeaderedContentControl Header="形状" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Avatar Size="50" Text="圆" Shape="Circle" Margin="0,0,20,0"/>
                        <flat:Avatar Size="50" Text="方" Shape="RoundedSquare"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 带徽标 -->
            <HeaderedContentControl Header="带徽标的头像" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <Grid Margin="0,0,30,0">
                            <flat:Avatar Size="50" Text="用户"/>
                            <flat:Badge Value="5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"/>
                        </Grid>
                        
                        <Grid Margin="0,0,30,0">
                            <flat:Avatar Size="50" Background="{StaticResource PrimaryBrush}" Text="管" Foreground="White"/>
                            <flat:Badge IsDot="True" Status="Success" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"/>
                        </Grid>
                        
                        <Grid>
                            <flat:Avatar Size="50" Background="{StaticResource SuccessBrush}" Text="在" Foreground="White"/>
                            <flat:Badge IsDot="True" Status="Processing" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"/>
                        </Grid>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 使用示例 -->
            <HeaderedContentControl Header="使用示例" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="15">
                        <StackPanel Orientation="Horizontal">
                            <flat:Avatar Size="50" Text="张" Margin="0,0,15,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="张三" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="产品经理" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
