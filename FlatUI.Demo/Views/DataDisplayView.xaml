<UserControl x:Class="FlatUI.Demo.Views.DataDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Virtualization Test (10,000 items)" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="Load Large Data" Click="LoadLargeData_Click" Style="{DynamicResource FlatButton}"/>
        </StackPanel>

        <DataGrid x:Name="BigDataGrid" Grid.Row="1" Style="{DynamicResource FlatDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="200"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <flat:Pagination Grid.Row="2" x:Name="BigPagination" Margin="0,10,0,0" 
                        TotalCount="10000" PageSize="50" 
                        ShowTotal="True" ShowJump="True"/>
    </Grid>
</UserControl>