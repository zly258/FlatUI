<UserControl x:Class="FlatUI.Demo.Views.DataDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="Table" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- Basic Table -->
            <HeaderedContentControl Header="基础表格" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <DataGrid Style="{DynamicResource FlatDataGrid}" AutoGenerateColumns="False" CanUserAddRows="False" Width="700">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- Table with Sorting -->
            <HeaderedContentControl Header="可排序表格（点击列头排序）" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <DataGrid Style="{DynamicResource FlatDataGrid}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserSortColumns="True" Width="700">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" SortDirection="Ascending"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="年龄" Binding="{Binding Age}" Width="80"/>
                            <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="点击列头进行排序" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- Table with Filter -->
            <HeaderedContentControl Header="可筛选表格" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="筛选:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="FilterCombo" Width="150" SelectedIndex="0" SelectionChanged="FilterCombo_SelectionChanged">
                            <ComboBoxItem Content="全部"/>
                            <ComboBoxItem Content="激活"/>
                            <ComboBoxItem Content="未激活"/>
                        </ComboBox>
                        <TextBox x:Name="SearchBox" Style="{DynamicResource FlatTextBox}" Width="200" Margin="10,0,0,0" TextChanged="SearchBox_TextChanged"/>
                    </StackPanel>
                    <DataGrid x:Name="FilterDataGrid" Style="{DynamicResource FlatDataGrid}" AutoGenerateColumns="False" CanUserAddRows="False" Width="700">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="数值" Binding="{Binding Value}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- Table with Single Selection (Radio) -->
            <HeaderedContentControl Header="单选模式表格" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <DataGrid x:Name="SingleSelectGrid" Style="{DynamicResource FlatDataGrid}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              SelectionMode="Single" SelectionUnit="FullRow" Width="700">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Mode=OneWay}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="获取选中项" Style="{DynamicResource FlatButton}" Click="GetSingleSelected_Click" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- Table with Multi Selection (CheckBox) -->
            <HeaderedContentControl Header="多选模式表格（复选框）" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="SelectAllCheck" Content="全选" Click="SelectAll_Click" Margin="0,0,20,0"/>
                        <Button Content="获取选中项" Style="{DynamicResource FlatButton}" Click="GetMultiSelected_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="MultiSelectGrid" Style="{DynamicResource FlatDataGrid}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              SelectionMode="Extended" SelectionUnit="FullRow" Width="700">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Mode=OneWay}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </HeaderedContentControl>
            
            <!-- Virtualization Test -->
            <HeaderedContentControl Header="大数据量测试（10,000条）" Style="{DynamicResource FlatCard}">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="性能测试：加载大量数据" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="加载大数据" Click="LoadLargeData_Click" Style="{DynamicResource FlatButton}"/>
                    </StackPanel>
                    <DataGrid x:Name="BigDataGrid" Style="{DynamicResource FlatDataGrid}" Width="700" Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="200"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <flat:Pagination x:Name="BigPagination" Margin="0,10,0,0" TotalCount="10000" PageSize="50" ShowTotal="True" ShowJump="True"/>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
