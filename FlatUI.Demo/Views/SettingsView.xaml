<UserControl x:Class="FlatUI.Demo.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <Grid Margin="20">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 语言设置 -->
            <HeaderedContentControl Header="Language / 语言" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="选择界面语言" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ComboBox x:Name="LanguageCombo" Width="200" HorizontalAlignment="Left" 
                              SelectionChanged="LanguageCombo_SelectionChanged"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="简体中文 (Chinese)" Tag="zh-CN"/>
                        <ComboBoxItem Content="English (英语)" Tag="en-US"/>
                    </ComboBox>
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" 
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="切换语言后，界面文本将立即更新。部分文本可能需要重新加载视图才能完全生效。"/>
                </StackPanel>
            </HeaderedContentControl>
            
            <HeaderedContentControl Header="Appearance" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="Mode" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton Content="Light" IsChecked="True" Click="LightMode_Click" Margin="0,0,20,0"/>
                        <RadioButton Content="Dark" Click="DarkMode_Click"/>
                    </StackPanel>

                    <TextBlock Text="Accent Color" FontWeight="Bold" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Width="30" Height="30" Background="#007ACC" Margin="0,0,10,10" Click="Accent_Click" Tag="#007ACC"/>
                        <Button Width="30" Height="30" Background="#107C10" Margin="0,0,10,10" Click="Accent_Click" Tag="#107C10"/>
                        <Button Width="30" Height="30" Background="#D83B01" Margin="0,0,10,10" Click="Accent_Click" Tag="#D83B01"/>
                        <Button Width="30" Height="30" Background="#A80000" Margin="0,0,10,10" Click="Accent_Click" Tag="#A80000"/>
                        <Button Width="30" Height="30" Background="#5C2D91" Margin="0,0,10,10" Click="Accent_Click" Tag="#5C2D91"/>
                        <Button Width="30" Height="30" Background="#008272" Margin="0,0,10,10" Click="Accent_Click" Tag="#008272"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <HeaderedContentControl Header="Window Info" Style="{DynamicResource FlatCard}">
                <StackPanel Margin="10">
                    <TextBlock Text="This window uses FlatWindow with custom chrome. The title bar buttons (Min/Max/Close) are fully functional and styled." 
                               TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </Grid>
</UserControl>