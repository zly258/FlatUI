<UserControl x:Class="FlatUI.Demo.Views.BubbleExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Bubble 气泡"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="气泡对话框"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础的气泡对话框。">
                <StackPanel>
                    <Border Background="#f5f5f5" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="Hello, how are you?" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#1890ff" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Right" MaxWidth="300">
                        <TextBlock Text="I'm fine, thank you!" TextWrapping="Wrap" Foreground="White"/>
                    </Border>
                    <Border Background="#f5f5f5" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="What are you doing today?" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#1890ff" CornerRadius="8" Padding="12" HorizontalAlignment="Right" MaxWidth="300">
                        <TextBlock Text="I'm working on a new project." TextWrapping="Wrap" Foreground="White"/>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同类型" Description="不同类型的气泡。">
                <StackPanel>
                    <Border Background="#f5f5f5" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="Default bubble" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#e6f7ff" BorderBrush="#91d5ff" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="Info bubble" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#f6ffed" BorderBrush="#b7eb8f" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="Success bubble" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#fffbe6" BorderBrush="#ffe58f" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="Warning bubble" TextWrapping="Wrap"/>
                    </Border>
                    <Border Background="#fff1f0" BorderBrush="#ffa39e" BorderThickness="1" CornerRadius="8" Padding="12" HorizontalAlignment="Left" MaxWidth="300">
                        <TextBlock Text="Error bubble" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
