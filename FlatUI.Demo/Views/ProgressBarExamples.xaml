<UserControl x:Class="FlatUI.Demo.Views.ProgressBarExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="ProgressBar 进度条"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="展示操作的当前进度"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础进度条" Description="标准的进度条。">
                <StackPanel>
                    <ProgressBar Value="30" Height="8" Margin="0,0,0,16"/>
                    <ProgressBar Value="50" Height="8" Margin="0,0,0,16"/>
                    <ProgressBar Value="70" Height="8" Margin="0,0,0,16"/>
                    <ProgressBar Value="100" Height="8"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="百分比显示" Description="显示进度的百分比。">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ProgressBar Value="30" Width="200" Height="8" Margin="0,0,8,0"/>
                        <TextBlock Text="30%" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ProgressBar Value="50" Width="200" Height="8" Margin="0,0,8,0"/>
                        <TextBlock Text="50%" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ProgressBar Value="70" Width="200" Height="8" Margin="0,0,8,0"/>
                        <TextBlock Text="70%" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ProgressBar Value="100" Width="200" Height="8" Margin="0,0,8,0"/>
                        <TextBlock Text="100%" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同尺寸" Description="不同高度的进度条。">
                <StackPanel>
                    <ProgressBar Value="30" Height="4" Margin="0,0,0,16"/>
                    <ProgressBar Value="50" Height="8" Margin="0,0,0,16"/>
                    <ProgressBar Value="70" Height="12" Margin="0,0,0,16"/>
                    <ProgressBar Value="100" Height="16"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="加载中" Description="加载中的进度条。">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Height="8" Margin="0,0,0,16"/>
                    <ProgressBar IsIndeterminate="True" Height="8" Foreground="{DynamicResource PrimaryBrush}"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
