<UserControl x:Class="FlatUI.Demo.Views.SwitchExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Switch 开关"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="开关选择器"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="简单的开关。">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Width="44" Height="22" Margin="0,0,8,0"/>
                        <TextBlock Text="Off" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Width="44" Height="22" IsChecked="True" Margin="0,0,8,0"/>
                        <TextBlock Text="On" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不可用状态" Description="开关不可用状态。">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Width="44" Height="22" IsEnabled="False" Margin="0,0,8,0"/>
                        <TextBlock Text="Disabled" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Width="44" Height="22" IsEnabled="False" IsChecked="True" Margin="0,0,8,0"/>
                        <TextBlock Text="Disabled &amp; Checked" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="加载中" Description="加载中状态。">
                <StackPanel Orientation="Horizontal">
                    <CheckBox Width="44" Height="22" IsEnabled="False" Margin="0,0,8,0"/>
                    <TextBlock Text="Loading..." VerticalAlignment="Center"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
