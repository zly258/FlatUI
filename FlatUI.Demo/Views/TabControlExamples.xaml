<UserControl x:Class="FlatUI.Demo.Views.TabControlExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="TabControl 标签页"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="选项卡切换组件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础的标签页。">
                <TabControl Width="400" Height="200">
                    <TabItem Header="Tab 1">
                        <TextBlock Text="Content of Tab Pane 1" Padding="16"/>
                    </TabItem>
                    <TabItem Header="Tab 2">
                        <TextBlock Text="Content of Tab Pane 2" Padding="16"/>
                    </TabItem>
                    <TabItem Header="Tab 3">
                        <TextBlock Text="Content of Tab Pane 3" Padding="16"/>
                    </TabItem>
                </TabControl>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="禁用某项" Description="禁用某个标签页。">
                <TabControl Width="400" Height="200">
                    <TabItem Header="Tab 1">
                        <TextBlock Text="Content of Tab Pane 1" Padding="16"/>
                    </TabItem>
                    <TabItem Header="Tab 2" IsEnabled="False">
                        <TextBlock Text="Content of Tab Pane 2" Padding="16"/>
                    </TabItem>
                    <TabItem Header="Tab 3">
                        <TextBlock Text="Content of Tab Pane 3" Padding="16"/>
                    </TabItem>
                </TabControl>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="图标" Description="带图标的标签页。">
                <TabControl Width="400" Height="200">
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Tab 1" Foreground="White"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBlock Text="Content of Tab Pane 1" Padding="16"/>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Tab 2" Foreground="White"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBlock Text="Content of Tab Pane 2" Padding="16"/>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Tab 3" Foreground="White"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBlock Text="Content of Tab Pane 3" Padding="16"/>
                    </TabItem>
                </TabControl>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="位置" Description="标签页的位置。">
                <StackPanel>
                    <TabControl Width="400" Height="150" Margin="0,0,0,16">
                        <TabItem Header="Tab 1">
                            <TextBlock Text="Content of Tab Pane 1" Padding="16"/>
                        </TabItem>
                        <TabItem Header="Tab 2">
                            <TextBlock Text="Content of Tab Pane 2" Padding="16"/>
                        </TabItem>
                    </TabControl>
                    <TabControl Width="400" Height="150">
                        <TabItem Header="Tab 1">
                            <TextBlock Text="Content of Tab Pane 1" Padding="16"/>
                        </TabItem>
                        <TabItem Header="Tab 2">
                            <TextBlock Text="Content of Tab Pane 2" Padding="16"/>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
