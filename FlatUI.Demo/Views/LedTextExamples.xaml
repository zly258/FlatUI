<UserControl x:Class="FlatUI.Demo.Views.LedTextExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="LedText LED文本"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="LED风格文本显示组件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础LED文本显示。">
                <Border Background="#000000" 
                        CornerRadius="8" 
                        Padding="24"
                        Width="400">
                    <TextBlock Text="HELLO WORLD" 
                               FontSize="48" 
                               FontWeight="Bold"
                               Foreground="#ff0000"
                               FontFamily="Consolas"
                               TextAlignment="Center"/>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同颜色" Description="不同颜色的LED文本。">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#000000" 
                            CornerRadius="8" 
                            Padding="16"
                            Width="120"
                            Margin="0,0,16,0">
                        <TextBlock Text="RED" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#ff0000"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                    </Border>
                    
                    <Border Background="#000000" 
                            CornerRadius="8" 
                            Padding="16"
                            Width="120"
                            Margin="0,0,16,0">
                        <TextBlock Text="GREEN" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#00ff00"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                    </Border>
                    
                    <Border Background="#000000" 
                            CornerRadius="8" 
                            Padding="16"
                            Width="120">
                        <TextBlock Text="BLUE" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#0000ff"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同尺寸" Description="不同尺寸的LED文本。">
                <StackPanel>
                    <Border Background="#000000" 
                            CornerRadius="8" 
                            Padding="16"
                            Width="400"
                            Margin="0,0,0,16">
                        <TextBlock Text="LARGE" 
                                   FontSize="64" 
                                   FontWeight="Bold"
                                   Foreground="#ff0000"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                    </Border>
                    
                    <Border Background="#000000" 
                            CornerRadius="8" 
                            Padding="16"
                            Width="400">
                        <TextBlock Text="SMALL" 
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   Foreground="#00ff00"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
