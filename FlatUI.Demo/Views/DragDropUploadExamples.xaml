<UserControl x:Class="FlatUI.Demo.Views.DragDropUploadExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="DragDropUpload 拖拽上传"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="支持拖拽文件上传的控件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="拖拽文件到指定区域上传。">
                <Border Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="48"
                        Width="400"
                        Height="200"
                        AllowDrop="True">
                    <StackPanel VerticalAlignment="Center">
                        <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"
                              Fill="{DynamicResource PrimaryBrush}"
                              Width="64"
                              Height="64"
                              Stretch="Uniform"
                              Margin="0,0,0,16"
                              HorizontalAlignment="Center"/>
                        <TextBlock Text="拖拽文件到此处上传"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="支持 JPG、PNG、PDF 等格式"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="带图标" Description="带图标的拖拽上传区域。">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="32"
                            Width="180"
                            Height="150"
                            AllowDrop="True"
                            Margin="0,0,16,0">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"
                                  Fill="#1890ff"
                                  Width="48"
                                  Height="48"
                                  Stretch="Uniform"
                                  Margin="0,0,0,12"
                                  HorizontalAlignment="Center"/>
                            <TextBlock Text="图片上传"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="32"
                            Width="180"
                            Height="150"
                            AllowDrop="True">
                        <StackPanel VerticalAlignment="Center">
                            <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                                  Fill="#52c41a"
                                  Width="48"
                                  Height="48"
                                  Stretch="Uniform"
                                  Margin="0,0,0,12"
                                  HorizontalAlignment="Center"/>
                            <TextBlock Text="文档上传"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
