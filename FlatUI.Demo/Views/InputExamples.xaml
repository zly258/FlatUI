<UserControl x:Class="FlatUI.Demo.Views.InputExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Input 输入框"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="通过鼠标或键盘输入内容"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础输入框。">
                <StackPanel>
                    <TextBlock Text="Basic usage" Margin="0,0,0,8"/>
                    <TextBox Width="300" Height="32" Padding="8,0" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="前置/后置标签" Description="用于配置一些固定组合。">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,1" Padding="8,0">
                            <TextBlock Text="http://" VerticalAlignment="Center"/>
                        </Border>
                        <TextBox Width="200" Height="32" Padding="8,0" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="200" Height="32" Padding="8,0" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
                        <Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,1,1" Padding="8,0">
                            <TextBlock Text=".com" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="搜索框" Description="带有搜索按钮的输入框。">
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="300" Height="32" Padding="8,0" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,8,0"/>
                    <Button Content="Search" Style="{DynamicResource PrimaryButton}"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="文本域" Description="用于多行输入。">
                <TextBox Width="400" Height="100" Padding="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" TextWrapping="Wrap" AcceptsReturn="True"/>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="禁用状态" Description="禁用状态。">
                <StackPanel>
                    <TextBox Width="300" Height="32" Padding="8,0" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsEnabled="False" Text="Disabled input" Margin="0,0,0,16"/>
                    <TextBox Width="400" Height="100" Padding="8" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsEnabled="False" Text="Disabled textarea" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
