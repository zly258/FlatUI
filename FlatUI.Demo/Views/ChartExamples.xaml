<UserControl x:Class="FlatUI.Demo.Views.ChartExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Chart 图表"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="数据可视化图表组件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础图表展示。">
                <Border Background="{DynamicResource RegionBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="24"
                        Height="300">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="销售数据统计" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                                <Border Background="{DynamicResource PrimaryBrush}" 
                                        Height="150" 
                                        Width="40" 
                                        CornerRadius="4"
                                        VerticalAlignment="Bottom"/>
                                <TextBlock Text="一月" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <Border Background="{DynamicResource PrimaryBrush}" 
                                        Height="200" 
                                        Width="40" 
                                        CornerRadius="4"
                                        VerticalAlignment="Bottom"/>
                                <TextBlock Text="二月" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Border Background="{DynamicResource PrimaryBrush}" 
                                        Height="120" 
                                        Width="40" 
                                        CornerRadius="4"
                                        VerticalAlignment="Bottom"/>
                                <TextBlock Text="三月" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                                <Border Background="{DynamicResource PrimaryBrush}" 
                                        Height="180" 
                                        Width="40" 
                                        CornerRadius="4"
                                        VerticalAlignment="Bottom"/>
                                <TextBlock Text="四月" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="折线图" Description="折线图展示。">
                <Border Background="{DynamicResource RegionBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="4"
                        Padding="24"
                        Height="300">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="用户增长趋势" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        
                        <Grid Grid.Row="1">
                            <Path Data="M0,200 L50,180 L100,150 L150,160 L200,120 L250,100 L300,80 L350,60 L400,40 L450,20"
                                  Stroke="{DynamicResource PrimaryBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent"/>
                            
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <TextBlock Text="1月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="2月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="3月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="4月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="5月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="6月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="7月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="8月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="9月" FontSize="12" Margin="0,0,40,0"/>
                                <TextBlock Text="10月" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
