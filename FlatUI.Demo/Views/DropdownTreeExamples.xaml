<UserControl x:Class="FlatUI.Demo.Views.DropdownTreeExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="DropdownTree 下拉树"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="支持下拉选择的树形控件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础下拉树选择。">
                <StackPanel>
                    <TextBlock Text="选择部门：" 
                               FontSize="14" 
                               Margin="0,0,0,8"/>
                    <ComboBox Width="300" Height="36">
                        <ComboBoxItem Content="技术部"/>
                        <ComboBoxItem Content="产品部"/>
                        <ComboBoxItem Content="市场部"/>
                        <ComboBoxItem Content="运营部"/>
                    </ComboBox>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="多级树" Description="多级树形结构。">
                <StackPanel>
                    <TextBlock Text="选择分类：" 
                               FontSize="14" 
                               Margin="0,0,0,8"/>
                    <ComboBox Width="300" Height="36">
                        <ComboBoxItem Content="电子产品 - 手机"/>
                        <ComboBoxItem Content="电子产品 - 电脑"/>
                        <ComboBoxItem Content="电子产品 - 平板"/>
                        <ComboBoxItem Content="服装 - 男装"/>
                        <ComboBoxItem Content="服装 - 女装"/>
                        <ComboBoxItem Content="服装 - 童装"/>
                        <ComboBoxItem Content="食品 - 零食"/>
                        <ComboBoxItem Content="食品 - 饮料"/>
                        <ComboBoxItem Content="食品 - 生鲜"/>
                    </ComboBox>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
