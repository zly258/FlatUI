<UserControl x:Class="FlatUI.Demo.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="欢迎使用 FlatUI"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,16"/>
            
            <TextBlock Text="企业级 WPF UI 设计语言和组件库"
                       FontSize="20"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,48"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24"
                        Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="设计语言"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="提供统一的设计规范和视觉风格，确保界面的一致性和专业性"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24"
                        Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="丰富组件"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="提供30+高质量组件，覆盖通用、布局、数据展示、反馈、输入等场景"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="易于使用"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="简洁的API设计，完善的文档和示例，快速上手"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <TextBlock Text="快速开始"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,48,0,24"/>
            
            <Border Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="安装"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,16"/>
                    
                    <Border Background="{DynamicResource BackgroundBrush}"
                            CornerRadius="4"
                            Padding="16">
                        <TextBlock Text="dotnet add package FlatUI.Library"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextBrush}"/>
                    </Border>
                    
                    <TextBlock Text="使用"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,32,0,16"/>
                    
                    <Border Background="{DynamicResource BackgroundBrush}"
                            CornerRadius="4"
                            Padding="16">
                        <TextBlock Text="&lt;Window x:Class=&quot;YourApp.MainWindow&quot;&#x0a;        xmlns=&quot;http://schemas.microsoft.com/winfx/2006/xaml/presentation&quot;&#x0a;        xmlns:flat=&quot;clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library&quot;&gt;&#x0a;    &lt;Grid&gt;&#x0a;        &lt;flat:FlatCard Header=&quot;Hello FlatUI&quot;&gt;&#x0a;            &lt;TextBlock Text=&quot;欢迎使用 FlatUI 组件库&quot;/&gt;&#x0a;        &lt;/flat:FlatCard&gt;&#x0a;    &lt;/Grid&gt;&#x0a;&lt;/Window&gt;"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
