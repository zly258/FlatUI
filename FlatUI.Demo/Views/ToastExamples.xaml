<UserControl x:Class="FlatUI.Demo.Views.ToastExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Toast 消息提示"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="轻量级的信息反馈组件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础消息提示。">
                <StackPanel>
                    <Button Content="成功提示" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="SuccessToast_Click"/>
                    <Button Content="信息提示" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="InfoToast_Click"/>
                    <Button Content="警告提示" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="WarningToast_Click"/>
                    <Button Content="错误提示" Style="{DynamicResource PrimaryButton}" Click="ErrorToast_Click"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同位置" Description="在不同位置显示消息提示。">
                <StackPanel>
                    <Button Content="顶部提示" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="TopToast_Click"/>
                    <Button Content="底部提示" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="BottomToast_Click"/>
                    <Button Content="左侧提示" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="LeftToast_Click"/>
                    <Button Content="右侧提示" Style="{DynamicResource PrimaryButton}" Click="RightToast_Click"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不同时长" Description="设置不同的显示时长。">
                <StackPanel>
                    <Button Content="2秒" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="ShortToast_Click"/>
                    <Button Content="5秒" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,8" Click="MediumToast_Click"/>
                    <Button Content="10秒" Style="{DynamicResource PrimaryButton}" Click="LongToast_Click"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
