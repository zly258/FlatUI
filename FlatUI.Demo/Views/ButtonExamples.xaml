<UserControl x:Class="FlatUI.Demo.Views.ButtonExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Button 按钮"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="按钮用于开始一个即时操作"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="按钮类型" Description="按钮有五种类型：主按钮、次按钮、虚线按钮、文本按钮和链接按钮。主按钮在同一个操作区域最多出现一次。">
                <StackPanel>
                    <Button Content="Primary Button" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Default Button" Style="{DynamicResource FlatButton}" Margin="0,8,8,8"/>
                    <Button Content="Dashed Button" Style="{DynamicResource FlatButton}" BorderThickness="2,2,2,2" Margin="0,8,8,8"/>
                    <Button Content="Text Button" Style="{DynamicResource FlatButton}" BorderThickness="0" Margin="0,8,8,8"/>
                    <Button Content="Link Button" Style="{DynamicResource FlatButton}" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}" Margin="0,8,8,8"/>
                    <Button Content="Danger Button" Style="{DynamicResource FlatButton}" BorderThickness="1" BorderBrush="#ff4d4f" Foreground="#ff4d4f" Margin="0,8,8,8"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="按钮形状" Description="支持圆形、圆角和方形按钮。">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Default" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Rounded" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Circle" Style="{DynamicResource PrimaryButton}" Width="40" Height="40" Margin="0,0,8,0"/>
                    <Button Content="Square" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="按钮尺寸" Description="按钮有大、中、小三种尺寸。通过设置 height 属性调整按钮大小。">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Large" Style="{DynamicResource PrimaryButton}" Height="40" Margin="0,0,8,0"/>
                    <Button Content="Default" Style="{DynamicResource PrimaryButton}" Height="32" Margin="0,0,8,0"/>
                    <Button Content="Small" Style="{DynamicResource PrimaryButton}" Height="24" Margin="0,0,8,0"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="加载中状态" Description="添加 loading 属性即可让按钮处于加载状态，点击两次后可恢复。">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Loading" Style="{DynamicResource PrimaryButton}" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="Click me!" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Loading" Style="{DynamicResource FlatButton}" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="Click me!" Style="{DynamicResource FlatButton}" Margin="0,0,8,0"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="图标按钮" Description="带图标的按钮可增强辨识度。">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Success"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" 
                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Info"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Warning"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Error"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="按钮组合" Description="可以将多个 Button 放入 Button.Group 容器中。">
                <Border Background="{DynamicResource RegionBrush}" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Left" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,0"/>
                        <Button Content="Middle" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,0"/>
                        <Button Content="Right" Style="{DynamicResource PrimaryButton}" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="不可用状态" Description="添加 disabled 属性即可让按钮处于不可用状态，同时按钮样式也会改变。">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Disabled" Style="{DynamicResource PrimaryButton}" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="Disabled" Style="{DynamicResource FlatButton}" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button Content="Disabled" Style="{DynamicResource FlatButton}" BorderThickness="0" IsEnabled="False" Margin="0,0,8,0"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
