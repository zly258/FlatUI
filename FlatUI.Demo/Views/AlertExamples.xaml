<UserControl x:Class="FlatUI.Demo.Views.AlertExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Alert 警告提示"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="警告提示，展现需要关注的信息"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="成功提示" Description="成功提示。">
                <Border Background="#F6FFED" BorderBrush="#B7EB8F" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                              Fill="#52C41A" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Success Text" VerticalAlignment="Center" Foreground="#52C41A"/>
                    </StackPanel>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="信息提示" Description="信息提示。">
                <Border Background="#E6F7FF" BorderBrush="#91D5FF" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                              Fill="#1890FF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Info Text" VerticalAlignment="Center" Foreground="#1890FF"/>
                    </StackPanel>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="警告提示" Description="警告提示。">
                <Border Background="#FFFBE6" BorderBrush="#FFE58F" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                              Fill="#FAAD14" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Warning Text" VerticalAlignment="Center" Foreground="#FAAD14"/>
                    </StackPanel>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="错误提示" Description="错误提示。">
                <Border Background="#FFF1F0" BorderBrush="#FFA39E" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                              Fill="#F5222D" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Error Text" VerticalAlignment="Center" Foreground="#F5222D"/>
                    </StackPanel>
                </Border>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="可关闭的警告提示" Description="显示关闭按钮，点击可关闭警告提示。">
                <Border Background="#E6F7FF" BorderBrush="#91D5FF" BorderThickness="1" CornerRadius="4" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                  Fill="#1890FF" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Info Text" VerticalAlignment="Center" Foreground="#1890FF"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1" Content="✕" Style="{DynamicResource FlatButton}" BorderThickness="0" Padding="4"/>
                    </Grid>
                </Border>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
