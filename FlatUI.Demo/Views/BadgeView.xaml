<UserControl x:Class="FlatUI.Demo.Views.BadgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="徽标组件" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- 数字徽标 -->
            <HeaderedContentControl Header="数字徽标" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <Grid Margin="0,0,20,0">
                            <Button Content="评论" Style="{DynamicResource FlatButton}"/>
                            <flat:Badge Value="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                        </Grid>
                        <Grid Margin="0,0,20,0">
                            <Button Content="消息" Style="{DynamicResource FlatButton}"/>
                            <flat:Badge Value="99" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                        </Grid>
                        <Grid>
                            <Button Content="通知" Style="{DynamicResource FlatButton}"/>
                            <flat:Badge Value="5" Status="Warning" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                        </Grid>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 状态点 -->
            <HeaderedContentControl Header="状态点" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <flat:Badge IsDot="True" Status="Default" Margin="0,0,8,0"/>
                            <TextBlock Text="默认" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <flat:Badge IsDot="True" Status="Success" Margin="0,0,8,0"/>
                            <TextBlock Text="成功" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <flat:Badge IsDot="True" Status="Warning" Margin="0,0,8,0"/>
                            <TextBlock Text="警告" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <flat:Badge IsDot="True" Status="Error" Margin="0,0,8,0"/>
                            <TextBlock Text="错误" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <flat:Badge IsDot="True" Status="Processing" Margin="0,0,8,0"/>
                            <TextBlock Text="处理中" VerticalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 不同尺寸 -->
            <HeaderedContentControl Header="不同尺寸" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Badge Value="10" BadgeSize="Small" Margin="0,0,20,0"/>
                        <flat:Badge Value="20" Margin="0,0,20,0"/>
                        <flat:Badge Value="30" BadgeSize="Large"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 独立使用 -->
            <HeaderedContentControl Header="独立使用" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <flat:Badge Value="5" Margin="0,0,20,0"/>
                        <flat:Badge Value="10" Status="Success" Margin="0,0,20,0"/>
                        <flat:Badge Value="15" Status="Warning" Margin="0,0,20,0"/>
                        <flat:Badge Value="20" Status="Error"/>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>

            <!-- 组合使用 -->
            <HeaderedContentControl Header="与头像组合" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <Grid Margin="0,0,30,0">
                            <flat:Avatar Size="50" Text="用"/>
                            <flat:Badge Value="3" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"/>
                        </Grid>
                        <Grid Margin="0,0,30,0">
                            <flat:Avatar Size="50" Background="{StaticResource PrimaryBrush}" Text="管" Foreground="White"/>
                            <flat:Badge IsDot="True" Status="Success" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"/>
                        </Grid>
                    </WrapPanel>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
