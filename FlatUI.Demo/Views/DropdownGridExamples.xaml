<UserControl x:Class="FlatUI.Demo.Views.DropdownGridExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="DropdownGrid 下拉网格"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="支持下拉选择的网格控件"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="基础下拉网格选择。">
                <StackPanel>
                    <TextBlock Text="选择产品：" 
                               FontSize="14" 
                               Margin="0,0,0,8"/>
                    <ComboBox Width="300" Height="36">
                        <ComboBoxItem Content="产品 A - $100"/>
                        <ComboBoxItem Content="产品 B - $200"/>
                        <ComboBoxItem Content="产品 C - $300"/>
                        <ComboBoxItem Content="产品 D - $400"/>
                    </ComboBox>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="带搜索" Description="带搜索功能的下拉网格。">
                <StackPanel>
                    <TextBlock Text="搜索并选择：" 
                               FontSize="14" 
                               Margin="0,0,0,8"/>
                    <ComboBox Width="300" Height="36">
                        <ComboBoxItem Content="选项 1"/>
                        <ComboBoxItem Content="选项 2"/>
                        <ComboBoxItem Content="选项 3"/>
                        <ComboBoxItem Content="选项 4"/>
                        <ComboBoxItem Content="选项 5"/>
                    </ComboBox>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="禁用状态" Description="禁用的下拉网格。">
                <StackPanel>
                    <TextBlock Text="禁用选择：" 
                               FontSize="14" 
                               Margin="0,0,0,8"/>
                    <ComboBox Width="300" Height="36" IsEnabled="False">
                        <ComboBoxItem Content="选项 1"/>
                        <ComboBoxItem Content="选项 2"/>
                        <ComboBoxItem Content="选项 3"/>
                    </ComboBox>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
