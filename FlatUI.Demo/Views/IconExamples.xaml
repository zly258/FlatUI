<UserControl x:Class="FlatUI.Demo.Views.IconExamples"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlatUI.Demo.Views"
             xmlns:controls="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Icon 图标"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,0,0,8"/>
            
            <TextBlock Text="语义化的矢量图形"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,32"/>
            
            <controls:FlatExampleContainer Title="基础用法" Description="使用 Path 组件展示图标。">
                <WrapPanel>
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Check" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Info" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Warning" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                              Fill="{DynamicResource ErrorBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Error" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Close" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Edit" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Delete" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Width="80" Margin="8">
                        <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" 
                              Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center"/>
                        <TextBlock Text="Add" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </WrapPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="图标尺寸" Description="通过设置 Width 和 Height 属性控制图标大小。">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource TextBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,16,0"/>
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource TextBrush}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,16,0"/>
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource TextBrush}" Width="32" Height="32" Stretch="Uniform" Margin="0,0,16,0"/>
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource TextBrush}" Width="48" Height="48" Stretch="Uniform"/>
                </StackPanel>
            </controls:FlatExampleContainer>
            
            <controls:FlatExampleContainer Title="图标颜色" Description="通过设置 Fill 属性控制图标颜色。">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource PrimaryBrush}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,16,0"/>
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource SuccessBrush}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,16,0"/>
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource WarningBrush}" Width="24" Height="24" Stretch="Uniform" Margin="0,0,16,0"/>
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                          Fill="{DynamicResource ErrorBrush}" Width="24" Height="24" Stretch="Uniform"/>
                </StackPanel>
            </controls:FlatExampleContainer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
