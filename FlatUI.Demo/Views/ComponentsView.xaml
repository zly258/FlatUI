<UserControl x:Class="FlatUI.Demo.Views.ComponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flat="clr-namespace:FlatUI.Library.Controls;assembly=FlatUI.Library"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="组件展示" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- 图表部分 -->
            <HeaderedContentControl Header="ECharts 风格图表" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Margin="10">
                        <TextBlock Text="折线图" FontWeight="Bold" Margin="0,0,0,10"/>
                        <flat:FlatChart x:Name="LineChart" Height="200" ChartType="Line" Title="销售趋势"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="柱状图" FontWeight="Bold" Margin="0,0,0,10"/>
                        <flat:FlatChart x:Name="BarChart" Height="200" ChartType="Bar" Title="月度对比"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Margin="10">
                        <TextBlock Text="面积图" FontWeight="Bold" Margin="0,0,0,10"/>
                        <flat:FlatChart x:Name="AreaChart" Height="200" ChartType="Area" Title="流量统计"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
                        <TextBlock Text="饼图" FontWeight="Bold" Margin="0,0,0,10"/>
                        <flat:FlatChart x:Name="PieChart" Height="200" ChartType="Pie" Title="市场份额"/>
                    </StackPanel>
                </Grid>
            </HeaderedContentControl>

            <WrapPanel>
                <!-- 头像组件 -->
                <HeaderedContentControl Header="头像组件" Style="{DynamicResource FlatCard}" Width="450" Margin="0,0,20,20">
                    <StackPanel Margin="10">
                        <TextBlock Text="不同尺寸" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <flat:Avatar Size="32" Text="小" Margin="0,0,10,0"/>
                            <flat:Avatar Size="40" Text="中" Margin="0,0,10,0"/>
                            <flat:Avatar Size="64" Text="大" Margin="0,0,10,0"/>
                            <flat:Avatar Size="96" Text="超大"/>
                        </WrapPanel>
                        
                        <TextBlock Text="不同类型" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <flat:Avatar Size="40" Text="JD" Margin="0,0,10,0"/>
                            <flat:Avatar Size="40" Background="{StaticResource PrimaryBrush}" Text="WP" Foreground="White" Margin="0,0,10,0"/>
                            <flat:Avatar Size="40" Background="{StaticResource SuccessBrush}" Text="OK" Foreground="White" Margin="0,0,10,0"/>
                            <flat:Avatar Size="40" Shape="RoundedSquare" Text="方"/>
                        </WrapPanel>
                        
                        <TextBlock Text="带徽标的头像" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <flat:Avatar Size="50" Text="用户"/>
                            <flat:Badge Value="5" IsDot="False" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"/>
                        </Grid>
                    </StackPanel>
                </HeaderedContentControl>

                <!-- 徽标组件 -->
                <HeaderedContentControl Header="徽标组件" Style="{DynamicResource FlatCard}" Width="450" Margin="0,0,20,20">
                    <StackPanel Margin="10">
                        <TextBlock Text="数字徽标" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,10,0">
                                <Button Content="评论" Style="{DynamicResource FlatButton}"/>
                                <flat:Badge Value="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                            </Grid>
                            <Grid Margin="0,0,10,0">
                                <Button Content="消息" Style="{DynamicResource FlatButton}"/>
                                <flat:Badge Value="99+" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                            </Grid>
                            <Grid>
                                <Button Content="通知" Style="{DynamicResource FlatButton}"/>
                                <flat:Badge Value="5" Status="Warning" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"/>
                            </Grid>
                        </WrapPanel>
                        
                        <TextBlock Text="状态点" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <flat:Badge IsDot="True" Status="Default" Margin="0,0,10,0"/>
                            <flat:Badge IsDot="True" Status="Success" Margin="0,0,10,0"/>
                            <flat:Badge IsDot="True" Status="Warning" Margin="0,0,10,0"/>
                            <flat:Badge IsDot="True" Status="Error" Margin="0,0,10,0"/>
                            <flat:Badge IsDot="True" Status="Processing" Margin="0,0,10,0"/>
                        </WrapPanel>
                        
                        <TextBlock Text="独立使用" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <flat:Badge Value="10" Margin="0,0,10,0"/>
                            <flat:Badge Value="20" BadgeSize="Large" Margin="0,0,10,0"/>
                            <flat:Badge Value="5" BadgeSize="Small"/>
                        </WrapPanel>
                    </StackPanel>
                </HeaderedContentControl>
            </WrapPanel>
            
            <WrapPanel>
                <!-- 标签组件 -->
                <HeaderedContentControl Header="标签组件" Style="{DynamicResource FlatCard}" Width="450" Margin="0,0,20,20">
                    <StackPanel Margin="10">
                        <TextBlock Text="默认标签" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <flat:Tag Content="默认" Margin="0,0,10,0"/>
                            <flat:Tag Content="主要" TagType="Primary" Margin="0,0,10,0"/>
                            <flat:Tag Content="成功" TagType="Success" Margin="0,0,10,0"/>
                            <flat:Tag Content="警告" TagType="Warning" Margin="0,0,10,0"/>
                            <flat:Tag Content="错误" TagType="Error"/>
                        </WrapPanel>
                        
                        <TextBlock Text="可关闭标签" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <flat:Tag Content="可关闭" Closable="True" Margin="0,0,10,0"/>
                            <flat:Tag Content="主要" TagType="Primary" Closable="True" Margin="0,0,10,0"/>
                            <flat:Tag Content="成功" TagType="Success" Closable="True"/>
                        </WrapPanel>
                        
                        <TextBlock Text="带图标标签" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,20">
                            <flat:Tag Content="收藏" Margin="0,0,10,0"/>
                            <flat:Tag Content="置顶" TagType="Primary" Margin="0,0,10,0"/>
                            <flat:Tag Content="热门" TagType="Success"/>
                        </WrapPanel>
                        
                        <TextBlock Text="可选择标签" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <flat:Tag Content="选项 1" Selectable="True" IsSelected="True" Margin="0,0,10,0"/>
                            <flat:Tag Content="选项 2" Selectable="True" Margin="0,0,10,0"/>
                            <flat:Tag Content="选项 3" Selectable="True"/>
                        </WrapPanel>
                    </StackPanel>
                </HeaderedContentControl>

                <!-- 气泡卡片组件 -->
                <HeaderedContentControl Header="气泡卡片" Style="{DynamicResource FlatCard}" Width="450" Margin="0,0,20,20">
                    <StackPanel Margin="10">
                        <TextBlock Text="左侧气泡（接收）" FontWeight="Bold" Margin="0,0,0,10"/>
                        <flat:Bubble Position="Left" SenderName="张三" Timestamp="{x:Static sys:DateTime.Now}" AvatarText="张" Margin="0,0,0,10">
                            <TextBlock Text="你好，这是一个测试消息。请问有什么可以帮助你的吗？" TextWrapping="Wrap"/>
                        </flat:Bubble>
                        
                        <TextBlock Text="右侧气泡（发送）" FontWeight="Bold" Margin="0,0,0,10"/>
                        <flat:Bubble Position="Right" SenderName="我" Timestamp="{x:Static sys:DateTime.Now}" AvatarText="我" BubbleBackground="{StaticResource PrimaryLightBrush}">
                            <TextBlock Text="谢谢！我想了解一下这个组件的使用方法。" TextWrapping="Wrap"/>
                        </flat:Bubble>
                    </StackPanel>
                </HeaderedContentControl>
            </WrapPanel>
            
            <!-- 综合示例 -->
            <HeaderedContentControl Header="综合应用示例" Style="{DynamicResource FlatCard}" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="聊天界面示例" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="10" MinHeight="300">
                        <StackPanel>
                            <!-- 对话 1 -->
                            <flat:Bubble Position="Left" SenderName="客服" Timestamp="{x:Static sys:DateTime.Now}" AvatarText="客" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="欢迎光临！请问有什么可以帮您？" TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,5,0,0">
                                        <flat:Tag Content="咨询" TagType="Info" TagSize="Small"/>
                                        <flat:Tag Content="在线" TagType="Success" TagSize="Small" Margin="5,0,0,0"/>
                                    </WrapPanel>
                                </StackPanel>
                            </flat:Bubble>
                            
                            <!-- 对话 2 -->
                            <flat:Bubble Position="Right" SenderName="用户" Timestamp="{x:Static sys:DateTime.Now}" AvatarText="用" BubbleBackground="{StaticResource PrimaryLightBrush}" Margin="0,0,0,10">
                                <TextBlock Text="我想了解一下这个产品的价格" TextWrapping="Wrap"/>
                            </flat:Bubble>
                            
                            <!-- 对话 3 -->
                            <flat:Bubble Position="Left" SenderName="客服" Timestamp="{x:Static sys:DateTime.Now}" AvatarText="客">
                                <StackPanel>
                                    <TextBlock Text="好的，这款产品的价格是：" TextWrapping="Wrap"/>
                                    <TextBlock Text="¥ 199.00" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <flat:Badge Value="3" DisplayText="热销" BadgeSize="Small" Margin="0,0,10,0"/>
                                        <flat:Tag Content="包邮" TagType="Success" TagSize="Small"/>
                                    </WrapPanel>
                                </StackPanel>
                            </flat:Bubble>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>